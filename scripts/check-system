#!/usr/bin/env bash
set -u

PROJECT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
CONFIG="$PROJECT_DIR/config/screenshot-tts.env"

ok=0
warn=0

check_cmd() {
  local name="$1"
  local path
  path="$(command -v "$name" || true)"
  if [[ -n "$path" ]]; then
    printf 'OK   %-18s %s\n' "$name" "$path"
  else
    printf 'MISS %-18s not found\n' "$name"
    ok=1
  fi
}

check_cmd spectacle
check_cmd tesseract
check_cmd pw-play
check_cmd pw-record
check_cmd ffmpeg
check_cmd uv
check_cmd kbuildsycoca6
check_cmd gdbus
check_cmd kwriteconfig6

printf '\nVersions:\n'
QT_QPA_PLATFORM=offscreen spectacle --version 2>/dev/null || true
if command -v tesseract >/dev/null 2>&1; then
  tesseract --version | sed -n '1p'
  printf 'Tesseract languages: '
  tesseract --list-langs 2>/dev/null | tail -n +2 | tr '\n' ' '
  printf '\n'
fi

printf '\nOmniVoice environment:\n'
PYTHON="$PROJECT_DIR/.venv/bin/python"
if [[ ! -x "$PYTHON" ]]; then
  PYTHON="$(command -v python3 || true)"
fi

if [[ -z "$PYTHON" ]]; then
  printf 'MISS python             not found\n'
  ok=1
else
  printf 'OK   python             %s\n' "$PYTHON"
"$PYTHON" - <<'PY'
import importlib.util
mods = ["torch", "soundfile", "omnivoice"]
missing = False
for name in mods:
    found = importlib.util.find_spec(name) is not None
    missing = missing or not found
    print(("OK   " if found else "MISS ") + f"python:{name}")
try:
    import torch
    print(f"INFO torch.cuda.is_available={torch.cuda.is_available()}")
    if torch.cuda.is_available():
        print(f"INFO torch.cuda.device_count={torch.cuda.device_count()}")
        print(f"INFO torch.cuda.device_name={torch.cuda.get_device_name(0)}")
except Exception as exc:
    print(f"WARN torch probe failed: {exc}")
raise SystemExit(1 if missing else 0)
PY
  if [[ $? -ne 0 ]]; then
    warn=1
  fi
fi

printf '\nConfig:\n'
if [[ -r "$CONFIG" ]]; then
  printf 'OK   config             %s\n' "$CONFIG"
  # shellcheck disable=SC1090
  source "$CONFIG"
else
  printf 'MISS config             copy config/example.env to config/screenshot-tts.env\n'
  warn=1
fi

if [[ -n "${STTS_REF_AUDIO:-}" ]]; then
  if [[ -r "$STTS_REF_AUDIO" ]]; then
    printf 'OK   reference audio    %s\n' "$STTS_REF_AUDIO"
  else
    printf 'MISS reference audio    %s\n' "$STTS_REF_AUDIO"
    warn=1
  fi
elif [[ -n "${STTS_OMNIVOICE_INSTRUCT:-}" ]]; then
  printf 'OK   voice design       %s\n' "$STTS_OMNIVOICE_INSTRUCT"
else
  printf 'OK   voice mode         OmniVoice auto voice\n'
fi

printf '\nHebrew TTS routing:\n'
printf 'OK   hebrew engine      %s\n' "${STTS_HEBREW_TTS_ENGINE:-auto}"
printf 'OK   hebrew threshold   %s\n' "${STTS_HEBREW_ROUTE_THRESHOLD:-0.35}"
printf 'OK   hebrew min chars   %s\n' "${STTS_HEBREW_ROUTE_MIN_CHARS:-3}"
printf 'OK   Blue speed         %s\n' "${STTS_BLUE_SPEED:-1.05}"
printf 'OK   Blue total step    %s\n' "${STTS_BLUE_TOTAL_STEP:-16}"
printf 'OK   hebrew detector    '
if printf 'שלום עולם' | "$PYTHON" "$PROJECT_DIR/bin/detect-text-language" | grep -F 'route=hebrew' >/dev/null; then
  printf 'routes Hebrew text to Hebrew TTS\n'
else
  printf 'failed\n'
  warn=1
fi

BLUE_ONNX_DIR="${STTS_BLUE_ONNX_DIR:-$PROJECT_DIR/models/blue-onnx-v2}"
BLUE_STYLE_JSON="${STTS_BLUE_STYLE_JSON:-$PROJECT_DIR/models/blue-voices/female1.json}"
BLUE_RENIKUD_MODEL="${STTS_BLUE_RENIKUD_MODEL:-$PROJECT_DIR/models/renikud/model.onnx}"
BLUE_PYTHON="${STTS_BLUE_PYTHON:-$PROJECT_DIR/.venv-blue/bin/python}"
blue_required=0
if [[ "${STTS_HEBREW_TTS_ENGINE:-auto}" == "blue" ]]; then
  blue_required=1
fi

if [[ -x "$BLUE_PYTHON" ]]; then
  printf 'OK   blue python        %s\n' "$BLUE_PYTHON"
else
  if [[ $blue_required -eq 1 ]]; then
    printf 'MISS blue python        %s\n' "$BLUE_PYTHON"
    warn=1
  else
    printf 'INFO blue python        %s (optional; run scripts/setup-hebrew-blue)\n' "$BLUE_PYTHON"
  fi
fi
if [[ -x "$BLUE_PYTHON" ]] && "$BLUE_PYTHON" -c "import blue_onnx" >/dev/null 2>&1; then
  printf 'OK   python:blue_onnx\n'
else
  if [[ $blue_required -eq 1 ]]; then
    printf 'MISS python:blue_onnx      run scripts/setup-hebrew-blue for dedicated Hebrew TTS\n'
    warn=1
  else
    printf 'INFO python:blue_onnx      optional dedicated Hebrew TTS is not installed\n'
  fi
fi
for pair in \
  "Blue ONNX dir:$BLUE_ONNX_DIR" \
  "Blue style JSON:$BLUE_STYLE_JSON" \
  "Blue renikud model:$BLUE_RENIKUD_MODEL"; do
  label="${pair%%:*}"
  path="${pair#*:}"
  if [[ -e "$path" ]]; then
    printf 'OK   %-18s %s\n' "$label" "$path"
  else
    if [[ $blue_required -eq 1 ]]; then
      printf 'MISS %-18s %s\n' "$label" "$path"
      warn=1
    else
      printf 'INFO %-18s %s (optional)\n' "$label" "$path"
    fi
  fi
done

if [[ $ok -ne 0 ]]; then
  printf '\nSystem check failed: install missing required commands.\n'
  exit 1
fi
if [[ $warn -ne 0 ]]; then
  printf '\nSystem check completed with setup warnings.\n'
  exit 2
fi
printf '\nSystem check passed.\n'
