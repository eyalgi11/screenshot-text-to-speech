#!/usr/bin/env bash
set -Eeuo pipefail

PROJECT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
VENV="${STTS_BLUE_VENV:-$PROJECT_DIR/.venv-blue}"
PYTHON_SPEC="${STTS_BLUE_PYTHON_SPEC:-python3.13}"
PY="$VENV/bin/python"
BLUE_EXTRA="${STTS_BLUE_EXTRA:-}"
BLUE_MODEL_REPO="${STTS_BLUE_MODEL_REPO:-notmax123/blue-onnx-v2}"
BLUE_ONNX_DIR="${STTS_BLUE_ONNX_DIR:-$PROJECT_DIR/models/blue-onnx-v2}"
BLUE_RENIKUD_DIR="${STTS_BLUE_RENIKUD_DIR:-$PROJECT_DIR/models/renikud}"
BLUE_STYLE_DIR="${STTS_BLUE_STYLE_DIR:-$PROJECT_DIR/models/blue-voices}"
BLUE_STYLE_NAME="${STTS_BLUE_STYLE_NAME:-female1.json}"
BLUE_STYLE_URL="${STTS_BLUE_STYLE_URL:-https://raw.githubusercontent.com/maxmelichov/BlueTTS/main/voices/$BLUE_STYLE_NAME}"

if [[ ! -x "$PY" ]]; then
  if command -v uv >/dev/null 2>&1; then
    echo "Creating BlueTTS virtualenv at $VENV using uv and $PYTHON_SPEC"
    uv venv --python "$PYTHON_SPEC" "$VENV"
  else
    echo "Creating BlueTTS virtualenv at $VENV using $PYTHON_SPEC"
    command -v "$PYTHON_SPEC" >/dev/null 2>&1 || {
      echo "Missing $PYTHON_SPEC. BlueTTS requires Python 3.12+." >&2
      exit 1
    }
    "$PYTHON_SPEC" -m venv "$VENV"
  fi
fi

python_version="$("$PY" - <<'PY'
import sys
print(f"{sys.version_info.major}.{sys.version_info.minor}")
PY
)"
case "$python_version" in
  3.12|3.13|3.14|3.15) ;;
  *)
    echo "BlueTTS requires Python 3.12+. Current venv Python is $python_version." >&2
    exit 1
    ;;
esac

if command -v uv >/dev/null 2>&1; then
  install_pkg=(uv pip install --python "$PY")
else
  "$PY" -m pip install --upgrade pip wheel
  install_pkg=("$PY" -m pip install)
fi

blue_pkg="blue-onnx"
if [[ -n "$BLUE_EXTRA" ]]; then
  blue_pkg="blue-onnx[$BLUE_EXTRA]"
fi

echo "Installing $blue_pkg and Hugging Face Hub"
"${install_pkg[@]}" "$blue_pkg" huggingface-hub

mkdir -p "$BLUE_ONNX_DIR" "$BLUE_RENIKUD_DIR" "$BLUE_STYLE_DIR"

echo "Downloading Blue ONNX model bundle: $BLUE_MODEL_REPO"
"$PY" - "$BLUE_MODEL_REPO" "$BLUE_ONNX_DIR" "$BLUE_RENIKUD_DIR" <<'PY'
import sys
from pathlib import Path
from huggingface_hub import snapshot_download, hf_hub_download

model_repo, onnx_dir, renikud_dir = sys.argv[1:4]
snapshot_download(
    repo_id=model_repo,
    repo_type="model",
    local_dir=onnx_dir,
)
hf_hub_download(
    repo_id="thewh1teagle/renikud",
    repo_type="model",
    filename="model.onnx",
    local_dir=renikud_dir,
)
Path(onnx_dir).mkdir(parents=True, exist_ok=True)
Path(renikud_dir).mkdir(parents=True, exist_ok=True)
PY

if [[ -r "$BLUE_ONNX_DIR/voices/$BLUE_STYLE_NAME" ]]; then
  echo "Copying default Blue voice style from downloaded model bundle: $BLUE_STYLE_NAME"
  cp "$BLUE_ONNX_DIR/voices/$BLUE_STYLE_NAME" "$BLUE_STYLE_DIR/$BLUE_STYLE_NAME"
else
  echo "Downloading default Blue voice style: $BLUE_STYLE_NAME"
  "$PY" - "$BLUE_STYLE_URL" "$BLUE_STYLE_DIR/$BLUE_STYLE_NAME" <<'PY'
import sys
import urllib.request
from pathlib import Path

url, output = sys.argv[1:3]
path = Path(output)
path.parent.mkdir(parents=True, exist_ok=True)
with urllib.request.urlopen(url) as response:
    data = response.read()
if not data.strip():
    raise SystemExit(f"Downloaded empty voice style from {url}")
path.write_bytes(data)
PY
fi

cat <<EOF
Done. Hebrew BlueTTS files:
  STTS_BLUE_ONNX_DIR=$BLUE_ONNX_DIR
  STTS_BLUE_STYLE_JSON=$BLUE_STYLE_DIR/$BLUE_STYLE_NAME
  STTS_BLUE_RENIKUD_MODEL=$BLUE_RENIKUD_DIR/model.onnx
  STTS_BLUE_PYTHON=$PY

Set this in config/screenshot-tts.env to force Blue for Hebrew:
  STTS_HEBREW_TTS_ENGINE=blue
EOF
