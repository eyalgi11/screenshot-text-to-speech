def parse_env_file(path: Path) -> dict[str, str]:
    config: dict[str, str] = {}
    if not path.exists():
        return config
    for raw in path.read_text(encoding="utf-8").splitlines():
        line = raw.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        try:
            config[key.strip()] = shlex.split(value, posix=True)[0] if value.strip() else ""
        except ValueError:
            config[key.strip()] = value.strip().strip('"').strip("'")
    return config


def available_langs() -> set[str]:
    proc = subprocess.run(["tesseract", "--list-langs"], capture_output=True, text=True, check=False)
    return {line.strip() for line in proc.stdout.splitlines()[1:] if line.strip()}


def default_ocr_lang(config: dict[str, str]) -> str:
    if config.get("STTS_OCR_LANG"):
        return config["STTS_OCR_LANG"]
    langs = available_langs()
    return "eng+heb" if {"eng", "heb"}.issubset(langs) else "eng"


def normalize(text: str) -> str:
    text = unicodedata.normalize("NFKC", text)
    text = "".join(ch for ch in text if ch not in BIDI_MARKS)
    text = text.replace("־", "-")
    text = re.sub(r"[ \t\r\f\v]+", " ", text)
    text = re.sub(r"\n\s+", "\n", text)
    text = re.sub(r"\s+\n", "\n", text)
    text = re.sub(r"\n{3,}", "\n\n", text)
    return text.strip().lower()


def levenshtein(a: list[str] | str, b: list[str] | str) -> int:
    if len(a) < len(b):
        a, b = b, a
    previous = list(range(len(b) + 1))
    for i, ca in enumerate(a, 1):
        current = [i]
        for j, cb in enumerate(b, 1):
            insert = current[j - 1] + 1
            delete = previous[j] + 1
            replace = previous[j - 1] + (ca != cb)
            current.append(min(insert, delete, replace))
        previous = current
    return previous[-1]


def error_rates(expected: str, actual: str) -> tuple[float, float]:
    expected_norm = normalize(expected)
    actual_norm = normalize(actual)
    char_den = max(len(expected_norm), 1)
    cer = levenshtein(expected_norm, actual_norm) / char_den
    expected_words = expected_norm.split()
    actual_words = actual_norm.split()
    wer = levenshtein(expected_words, actual_words) / max(len(expected_words), 1)
    return cer, wer


def pango_markup(case: Case) -> str:
    escaped = html.escape(case.text)
    return f'<span font_desc="DejaVu Sans {case.font_size}">{escaped}</span>'


def run(cmd: list[str], *, input_text: str | None = None) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        cmd,
        input=input_text,
        capture_output=True,
        text=True,
        check=False,
    )


def generate_image(case: Case, path: Path) -> None:
    border_size = "44" if "camera_warp" in case.effects else "28"
    base = [
        "magick",
        "-seed",
        str(sum(ord(ch) for ch in case.id)),
        "-background",
        case.background,
        "-fill",
        case.fill,
        "-size",
        f"{case.width}x",
        f"pango:{pango_markup(case)}",
        "-bordercolor",
        case.background,
        "-border",
        border_size,
    ]
    effects: list[str] = []
    overlay_effects: list[str] = []
    post_effects: list[str] = []
    for effect in case.effects:
        if effect == "blur":
            effects.extend(["-blur", "0x0.7"])
        elif effect == "noise":
            effects.extend(["+noise", "Gaussian"])
        elif effect == "resize_75":
            effects.extend(["-resize", "75%"])
        elif effect == "resize_80":
            effects.extend(["-resize", "80%"])
        elif effect == "resize_90":
            effects.extend(["-resize", "90%"])
        elif effect == "rotate_1":
            effects.extend(["-background", case.background, "-rotate", "1"])
        elif effect in OVERLAY_EFFECTS:
            overlay_effects.append(effect)
        elif effect in POST_EFFECTS:
            post_effects.append(effect)
        else:
            raise ValueError(f"Unknown effect: {effect}")

    proc = run([*base, *effects, str(path)])
    if proc.returncode != 0:
        raise RuntimeError(f"Image generation failed for {case.id}:\n{proc.stderr}")
    for effect in overlay_effects:
        apply_overlay_effect(case, path, effect)
    for effect in post_effects:
        apply_post_effect(case, path, effect)
    strip_image_metadata(path)


def image_size(path: Path) -> tuple[int, int]:
    proc = run(["magick", "identify", "-format", "%w %h", str(path)])
    if proc.returncode != 0:
        raise RuntimeError(f"Could not inspect image size for {path}:\n{proc.stderr}")
    width, height = proc.stdout.strip().split()
    return int(width), int(height)


def draw_text_command(x: int, y: int, text: str) -> str:
    safe = text.replace("\\", "\\\\").replace("'", "\\'")
    return f"text {x},{y} '{safe}'"


def apply_overlay_effect(case: Case, path: Path, effect: str) -> None:
    width, height = image_size(path)
    rng = random.Random(f"{case.id}:{effect}")
    args: list[str] = []

    if effect == "thin_rules":
        args.extend(["-stroke", "#d2d6cf", "-strokewidth", "1", "-fill", "none"])
        for _ in range(5):
            y = rng.randint(18, max(20, height - 18))
            args.extend(["-draw", f"line 12,{y} {max(24, width - 12)},{y}"])
        for _ in range(4):
            x = rng.randint(20, max(24, width - 20))
            args.extend(["-draw", f"line {x},10 {x},{max(20, height - 10)}"])
        for _ in range(3):
            x1 = rng.randint(8, max(10, width // 3))
            y1 = rng.randint(8, max(10, height // 2))
            x2 = min(width - 8, x1 + rng.randint(60, 180))
            y2 = min(height - 8, y1 + rng.randint(22, 58))
            args.extend(["-draw", f"rectangle {x1},{y1} {x2},{y2}"])

    elif effect == "edge_badges":
        tokens = ["OK", "?", "x", "!", "::", "copy", "tap", "ID", "#", "⋯"]
        args.extend(["-font", "DejaVu-Sans", "-fill", "#9aa19a"])
        for _ in range(8):
            token = rng.choice(tokens)
            size = rng.randint(12, 20)
            x1 = rng.choice([rng.randint(8, 110), rng.randint(max(12, width - 150), max(14, width - 55))])
            y1 = rng.randint(12, max(18, height - 34))
            x2 = min(width - 8, x1 + rng.randint(34, 84))
            y2 = min(height - 8, y1 + rng.randint(20, 34))
            args.extend(
                [
                    "-fill",
                    "#e7ebe4",
                    "-stroke",
                    "#c8cec4",
                    "-strokewidth",
                    "1",
                    "-draw",
                    f"roundrectangle {x1},{y1} {x2},{y2} 6,6",
                    "-stroke",
                    "none",
                    "-fill",
                    "#8b918a",
                    "-pointsize",
                    str(size),
                    "-draw",
                    draw_text_command(x1 + 8, y1 + size + 2, token),
                ]
            )

    elif effect == "ui_symbol_distractors":
        tokens = ["[ ]", "[x]", "::", "||", "!!", "?", "#", "@", "0O", "1lI", "<>", "/\\", "++", "--"]
        args.extend(["-font", "DejaVu-Sans", "-fill", "#8b918a"])
        for _ in range(14):
            token = rng.choice(tokens)
            size = rng.randint(13, 24)
            if rng.random() < 0.55:
                x = rng.choice([rng.randint(6, 80), rng.randint(max(8, width - 130), max(10, width - 45))])
                y = rng.randint(18, max(20, height - 8))
            else:
                x = rng.randint(6, max(8, width - 70))
                y = rng.choice([rng.randint(16, 36), rng.randint(max(20, height - 34), max(22, height - 8))])
            args.extend(["-pointsize", str(size), "-draw", draw_text_command(x, y, token)])

    elif effect == "watermark_symbols":
        tokens = ["@", "#", "?", "0O", "I1", "<>", "[]", "||", "⋯", "₪", "%"]
        args.extend(["-font", "DejaVu-Sans", "-fill", "#a8ada6"])
        for _ in range(10):
            token = rng.choice(tokens)
            size = rng.randint(26, 58)
            x = rng.randint(4, max(8, width - 92))
            y = rng.randint(30, max(34, height - 8))
            args.extend(["-pointsize", str(size), "-draw", draw_text_command(x, y, token)])

    elif effect == "math_symbol_distractors":
        tokens = ["+", "-", "*", "/", "=", "!=", "<=", ">=", "~=", "()", "[]", "{}", "x2", "O0", "l1", "..."]
        args.extend(["-font", "DejaVu-Sans", "-fill", "#858585"])
        for _ in range(20):
            token = rng.choice(tokens)
            size = rng.randint(12, 22)
            if rng.random() < 0.5:
                x = rng.choice([rng.randint(8, 90), rng.randint(max(10, width - 120), max(12, width - 45))])
                y = rng.randint(18, max(20, height - 8))
            else:
                x = rng.randint(8, max(10, width - 60))
                y = rng.choice([rng.randint(18, 42), rng.randint(max(20, height - 40), max(22, height - 8))])
            args.extend(["-pointsize", str(size), "-draw", draw_text_command(x, y, token)])

    else:
        raise ValueError(f"Unknown overlay effect: {effect}")

    tmp = path.with_suffix(f".{effect}.png")
    proc = run(["magick", str(path), *args, str(tmp)])
    if proc.returncode != 0:
        raise RuntimeError(f"Overlay effect {effect} failed for {case.id}:\n{proc.stderr}")
    tmp.replace(path)


def apply_post_effect(case: Case, path: Path, effect: str) -> None:
    width, height = image_size(path)
    tmp = path.with_suffix(f".{effect}.png")

    if effect == "paper_texture":
        seed = str(sum(ord(ch) for ch in f"{case.id}:{effect}"))
        proc = run(
            [
                "magick",
                "-seed",
                seed,
                str(path),
                "-attenuate",
                "0.10",
                "+noise",
                "Gaussian",
                "-brightness-contrast",
                "1x4",
                str(tmp),
            ]
        )

    elif effect == "camera_warp":
        points = (
            f"0,0 8,6 "
            f"{width},0 {max(0, width - 10)},11 "
            f"0,{height} 12,{max(0, height - 6)} "
            f"{width},{height} {max(0, width - 15)},{max(0, height - 3)}"
        )
        proc = run(
            [
                "magick",
                str(path),
                "-virtual-pixel",
                "edge",
                "-distort",
                "Perspective",
                points,
                "+repage",
                "-blur",
                "0x0.25",
                str(tmp),
            ]
        )

    elif effect == "jpeg_artifacts":
        jpg = path.with_suffix(".jpeg-artifacts.jpg")
        proc = run(["magick", str(path), "-quality", "38", str(jpg)])
        if proc.returncode == 0:
            proc = run(["magick", str(jpg), str(tmp)])
        if jpg.exists():
            jpg.unlink()

    else:
        raise ValueError(f"Unknown post effect: {effect}")

    if proc.returncode != 0:
        raise RuntimeError(f"Post effect {effect} failed for {case.id}:\n{proc.stderr}")
    tmp.replace(path)


def strip_image_metadata(path: Path) -> None:
    tmp = path.with_suffix(".stripped.png")
    proc = run(["magick", str(path), "-strip", "-define", "png:exclude-chunk=all", str(tmp)])
    if proc.returncode != 0:
        raise RuntimeError(f"Could not strip image metadata for {path}:\n{proc.stderr}")
    tmp.replace(path)


def preprocess_image(input_path: Path, output_path: Path) -> None:
    proc = run(
        [
            "magick",
            str(input_path),
            "-colorspace",
            "Gray",
            "-resize",
            "200%",
            "-sigmoidal-contrast",
            "8x50%",
            "-sharpen",
            "0x1",
            str(output_path),
        ]
    )
    if proc.returncode != 0:
        raise RuntimeError(f"Preprocess failed for {input_path}:\n{proc.stderr}")


def ocr_image(path: Path, lang: str, psm: str) -> tuple[str, str]:
    proc = run(["tesseract", str(path), "stdout", "-l", lang, "--psm", psm])
    return proc.stdout, proc.stderr


def ocr_image_auto(path: Path, output_path: Path, preprocessed_path: Path, lang: str, psm: str) -> tuple[str, str]:
    proc = run(
        [
            sys.executable,
            str(PROJECT_DIR / "bin" / "ocr-image"),
            "--image",
            str(path),
            "--output",
            str(output_path),
            "--lang",
            lang,
            "--psm",
            psm,
            "--preprocess",
            "auto",
            "--preprocessed-image",
            str(preprocessed_path),
        ]
    )
    text = output_path.read_text(encoding="utf-8") if output_path.exists() else ""
    return text, proc.stderr


def detect_route(text: str, config: dict[str, str]) -> tuple[str, dict[str, str]]:
    threshold = config.get("STTS_HEBREW_ROUTE_THRESHOLD", "0.35")
    min_chars = config.get("STTS_HEBREW_ROUTE_MIN_CHARS", "3")
    proc = run(
        [
            sys.executable,
            str(PROJECT_DIR / "bin" / "detect-text-language"),
            "--hebrew-threshold",
            threshold,
            "--hebrew-min-chars",
            min_chars,
        ],
        input_text=text,
    )
    parsed: dict[str, str] = {}
    for line in proc.stdout.splitlines():
        if "=" in line:
            key, value = line.split("=", 1)
            parsed[key] = value
    return parsed.get("route", "unknown"), parsed


def write_markdown_report(results: list[dict[str, object]], out_dir: Path, lang: str, psm: str, mode: str) -> None:
    failures = [row for row in results if not row["passed"]]
    blocking_failures = [row for row in failures if row["required"]]
    challenge_failures = [row for row in failures if not row["required"]]
    lines = [
        "# OCR Stress Report",
        "",
        f"- Generated: {time.strftime('%Y-%m-%d %H:%M:%S %Z')}",
        f"- OCR language: `{lang}`",
        f"- Tesseract PSM: `{psm}`",
        f"- Mode: `{mode}`",
        f"- Cases: {len(results)}",
        f"- Failures: {len(failures)}",
        f"- Blocking failures: {len(blocking_failures)}",
        f"- Challenge failures: {len(challenge_failures)}",
        "",
        "| Case | Tier | Mode | CER | WER | Route | Expected Route | Result | Notes |",
        "| --- | --- | --- | ---: | ---: | --- | --- | --- | --- |",
    ]
    for row in results:
        tier = "required" if row["required"] else "challenge"
        result = "pass" if row["passed"] else "FAIL" if row["required"] else "WARN"
        lines.append(
            "| {case} | {tier} | {mode} | {cer:.3f} | {wer:.3f} | {route} | {expected_route} | {result} | {notes} |".format(
                case=row["case"],
                tier=tier,
                mode=row["mode"],
                cer=row["cer"],
                wer=row["wer"],
                route=row["route"],
                expected_route=row["expected_route"],
                result=result,
                notes=str(row["notes"]).replace("|", "\\|"),
            )
        )
    lines.append("")
    lines.append("## OCR Text")
    for row in results:
        lines.extend(
            [
                "",
                f"### {row['case']} ({row['mode']})",
                "",
                f"- Image: `{row['image']}`",
                f"- Ground truth: `{row['truth_file']}`",
                f"- OCR file: `{row['ocr_file']}`",
                f"- OCR stderr: `{row['stderr_file']}`",
                "",
                "```text",
                str(row["ocr_text"]).strip(),
                "```",
            ]
        )
    (out_dir / "report.md").write_text("\n".join(lines) + "\n", encoding="utf-8")


def write_html_report(results: list[dict[str, object]], out_dir: Path, lang: str, psm: str, mode: str) -> None:
    failures = [row for row in results if not row["passed"]]
    blocking_failures = [row for row in failures if row["required"]]
    challenge_failures = [row for row in failures if not row["required"]]

    def esc(value: object) -> str:
        return html.escape(str(value), quote=True)

    def status(row: dict[str, object]) -> str:
        if row["passed"]:
            return "pass"
        return "fail" if row["required"] else "warn"

    def image_data_uri(row: dict[str, object]) -> str:
        image_path = out_dir / str(row["image"])
        encoded = base64.b64encode(image_path.read_bytes()).decode("ascii")
        return f"data:image/png;base64,{encoded}"

    summary_rows = []
    for row in results:
        row_status = status(row)
        summary_rows.append(
            "<tr>"
            f"<td><a href=\"#{esc(row['case'])}-{esc(row['mode'])}\">{esc(row['case'])}</a></td>"
            f"<td>{'required' if row['required'] else 'challenge'}</td>"
            f"<td>{esc(row['mode'])}</td>"
            f"<td class=\"num\">{float(row['cer']):.3f}</td>"
            f"<td class=\"num\">{float(row['wer']):.3f}</td>"
            f"<td>{esc(row['route'])}</td>"
            f"<td>{esc(row['expected_route'])}</td>"
            f"<td><span class=\"pill {row_status}\">{row_status}</span></td>"
            "</tr>"
        )

    detail_cards = []
    for row in results:
        row_status = status(row)
        detail_cards.append(
            f"<section class=\"case\" id=\"{esc(row['case'])}-{esc(row['mode'])}\">"
            "<div class=\"case-head\">"
            "<div>"
            f"<h2>{esc(row['case'])}</h2>"
            f"<p>{esc(row['notes'])}</p>"
            "</div>"
            f"<span class=\"pill {row_status}\">{row_status}</span>"
            "</div>"
            "<div class=\"metrics\">"
            f"<div><span>CER</span><b>{float(row['cer']):.3f}</b><small>limit {float(row['max_cer']):.3f}</small></div>"
            f"<div><span>WER</span><b>{float(row['wer']):.3f}</b></div>"
            f"<div><span>Route</span><b>{esc(row['route'])}</b><small>expected {esc(row['expected_route'])}</small></div>"
            f"<div><span>Mode</span><b>{esc(row['mode'])}</b></div>"
            f"<div><span>Tier</span><b>{'required' if row['required'] else 'challenge'}</b></div>"
            "</div>"
            "<div class=\"inspect-grid\">"
            "<figure>"
            f"<img src=\"{image_data_uri(row)}\" alt=\"Generated OCR test image for {esc(row['case'])}\">"
            f"<figcaption>Generated image: {esc(row['image'])}</figcaption>"
            "</figure>"
            "<div class=\"text-pair\">"
            "<div>"
            "<h3>Ground Truth</h3>"
            f"<pre dir=\"auto\">{esc(row['truth_text'])}</pre>"
            "</div>"
            "<div>"
            "<h3>OCR Output</h3>"
            f"<pre dir=\"auto\">{esc(row['ocr_text']).strip()}</pre>"
            "</div>"
            "</div>"
            "</div>"
            "<details>"
            "<summary>Route and OCR diagnostics</summary>"
            f"<pre>{esc(json.dumps(row['route_info'], indent=2, ensure_ascii=False))}</pre>"
            f"<pre>{esc(row['stderr_text']).strip()}</pre>"
            "</details>"
            "</section>"
        )

    html_text = f"""<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>OCR Stress Report</title>
  <style>
    :root {{
      color-scheme: light;
      --bg: #f5f6f2;
      --panel: #ffffff;
      --ink: #1f2328;
      --muted: #5d6773;
      --line: #d8ddd2;
      --pass: #12633f;
      --pass-bg: #dff3e8;
      --warn: #8a5a00;
      --warn-bg: #fff1c7;
      --fail: #9e2b25;
      --fail-bg: #f8dfdc;
      --accent: #365f91;
    }}
    * {{ box-sizing: border-box; }}
    body {{
      margin: 0;
      background: var(--bg);
      color: var(--ink);
      font: 15px/1.45 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }}
    main {{
      width: min(1180px, calc(100% - 32px));
      margin: 0 auto;
      padding: 28px 0 44px;
    }}
    header {{
      margin-bottom: 22px;
    }}
    h1 {{
      margin: 0 0 8px;
      font-size: 30px;
      letter-spacing: 0;
    }}
    h2 {{
      margin: 0;
      font-size: 20px;
      letter-spacing: 0;
    }}
    h3 {{
      margin: 0 0 8px;
      font-size: 14px;
      letter-spacing: 0;
    }}
    p {{ margin: 0; color: var(--muted); }}
    .overview {{
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 10px;
      margin: 18px 0;
    }}
    .stat, .case {{
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 8px;
    }}
    .stat {{
      padding: 12px;
    }}
    .stat span {{
      display: block;
      color: var(--muted);
      font-size: 12px;
    }}
    .stat b {{
      display: block;
      margin-top: 4px;
      font-size: 24px;
    }}
    .table-wrap {{
      overflow-x: auto;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--panel);
      margin-bottom: 18px;
    }}
    table {{
      width: 100%;
      border-collapse: collapse;
      min-width: 760px;
    }}
    th, td {{
      padding: 9px 10px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      vertical-align: top;
    }}
    th {{
      background: #ecefe8;
      color: #30363d;
      font-size: 12px;
      font-weight: 700;
    }}
    tr:last-child td {{ border-bottom: 0; }}
    a {{ color: var(--accent); }}
    .num {{
      font-variant-numeric: tabular-nums;
      text-align: right;
    }}
    .pill {{
      display: inline-flex;
      align-items: center;
      min-height: 24px;
      padding: 2px 9px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
    }}
    .pill.pass {{ background: var(--pass-bg); color: var(--pass); }}
    .pill.warn {{ background: var(--warn-bg); color: var(--warn); }}
    .pill.fail {{ background: var(--fail-bg); color: var(--fail); }}
    .case {{
      padding: 16px;
      margin-top: 16px;
    }}
    .case-head {{
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 14px;
    }}
    .metrics {{
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
      gap: 10px;
      margin-bottom: 14px;
    }}
    .metrics div {{
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 10px;
      background: #fbfcf9;
    }}
    .metrics span, .metrics small {{
      display: block;
      color: var(--muted);
      font-size: 12px;
    }}
    .metrics b {{
      display: block;
      margin: 2px 0;
      font-size: 20px;
      word-break: break-word;
    }}
    .inspect-grid {{
      display: grid;
      grid-template-columns: minmax(260px, 0.9fr) minmax(320px, 1.1fr);
      gap: 14px;
      align-items: start;
    }}
    figure {{
      margin: 0;
      border: 1px solid var(--line);
      border-radius: 8px;
      overflow: hidden;
      background: #fdfdfb;
    }}
    img {{
      display: block;
      width: 100%;
      height: auto;
      max-height: 420px;
      object-fit: contain;
      border-bottom: 1px solid var(--line);
    }}
    figcaption {{
      padding: 8px 10px;
      color: var(--muted);
      font-size: 12px;
    }}
    .text-pair {{
      display: grid;
      gap: 12px;
    }}
    .text-pair > div, details {{
      border: 1px solid var(--line);
      border-radius: 8px;
      background: #fbfcf9;
      padding: 10px;
    }}
    pre {{
      margin: 0;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      font: 13px/1.45 ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
    }}
    details {{
      margin-top: 14px;
    }}
    summary {{
      cursor: pointer;
      color: var(--accent);
      font-weight: 700;
    }}
    details pre {{
      margin-top: 10px;
      color: #30363d;
    }}
    @media (max-width: 820px) {{
      main {{ width: min(100% - 20px, 1180px); padding-top: 18px; }}
      .inspect-grid {{ grid-template-columns: 1fr; }}
      .case-head {{ align-items: stretch; flex-direction: column; }}
    }}
  </style>
</head>
<body>
  <main>
    <header>
      <h1>OCR Stress Report</h1>
      <p>Generated {esc(time.strftime('%Y-%m-%d %H:%M:%S %Z'))}. OCR language {esc(lang)}, PSM {esc(psm)}, mode {esc(mode)}.</p>
    </header>
    <section class="overview" aria-label="Summary">
      <div class="stat"><span>Cases</span><b>{len(results)}</b></div>
      <div class="stat"><span>Failures</span><b>{len(failures)}</b></div>
      <div class="stat"><span>Blocking Failures</span><b>{len(blocking_failures)}</b></div>
      <div class="stat"><span>Challenge Warnings</span><b>{len(challenge_failures)}</b></div>
      <div class="stat"><span>OCR Language</span><b>{esc(lang)}</b></div>
      <div class="stat"><span>Mode</span><b>{esc(mode)}</b></div>
    </section>
    <section class="table-wrap" aria-label="Result table">
      <table>
        <thead>
          <tr>
            <th>Case</th>
            <th>Tier</th>
            <th>Mode</th>
            <th class="num">CER</th>
            <th class="num">WER</th>
            <th>Route</th>
            <th>Expected</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {''.join(summary_rows)}
        </tbody>
      </table>
    </section>
    {''.join(detail_cards)}
  </main>
</body>
</html>
"""
    (out_dir / "report.html").write_text(html_text, encoding="utf-8")


def write_report(results: list[dict[str, object]], out_dir: Path, lang: str, psm: str, mode: str) -> None:
    write_markdown_report(results, out_dir, lang, psm, mode)
    write_html_report(results, out_dir, lang, psm, mode)
    (out_dir / "results.json").write_text(json.dumps(results, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")


def case_subset(names: str | None) -> Iterable[Case]:
    if not names:
        return CASES
    wanted = {name.strip() for name in names.split(",") if name.strip()}
    selected = [case for case in CASES if case.id in wanted]
    missing = wanted - {case.id for case in selected}
    if missing:
        raise SystemExit(f"Unknown case(s): {', '.join(sorted(missing))}")
    return selected


def main() -> int:
    p = argparse.ArgumentParser(description="Generate difficult OCR images and score Tesseract/TTS routing")
    p.add_argument("--out-dir", default=str(DEFAULT_OUT_DIR), help="Artifact directory")
    p.add_argument("--lang", help="Tesseract language, default from config or eng+heb")
    p.add_argument("--psm", help="Tesseract page segmentation mode, default from config or 6")
    p.add_argument("--mode", choices=["auto", "raw", "preprocessed", "both", "all"], default="auto")
    p.add_argument("--cases", help="Comma-separated case ids to run")
    p.add_argument("--no-clean", action="store_true", help="Keep existing output directory contents")
    args = p.parse_args()

    for command in ("magick", "tesseract"):
        if not shutil.which(command):
            raise SystemExit(f"Missing command: {command}")

    config = parse_env_file(PROJECT_DIR / "config" / "screenshot-tts.env")
    lang = args.lang or default_ocr_lang(config)
    psm = args.psm or config.get("STTS_OCR_PSM", "6")
    out_dir = Path(args.out_dir).expanduser()
    if out_dir.exists() and not args.no_clean:
        shutil.rmtree(out_dir)
    (out_dir / "images").mkdir(parents=True, exist_ok=True)
    (out_dir / "truth").mkdir(parents=True, exist_ok=True)
    (out_dir / "ocr").mkdir(parents=True, exist_ok=True)

    modes = ["raw", "preprocessed"] if args.mode == "both" else ["raw", "preprocessed", "auto"] if args.mode == "all" else [args.mode]
    results: list[dict[str, object]] = []

    for case in case_subset(args.cases):
        image = out_dir / "images" / f"{case.id}.png"
        truth_file = out_dir / "truth" / f"{case.id}.txt"
        generate_image(case, image)
        truth_file.write_text(case.text + "\n", encoding="utf-8")

        for mode in modes:
            ocr_input = image
            if mode == "preprocessed":
                ocr_input = out_dir / "images" / f"{case.id}.preprocessed.png"
                preprocess_image(image, ocr_input)

            ocr_file = out_dir / "ocr" / f"{case.id}.{mode}.txt"
            stderr_file = out_dir / "ocr" / f"{case.id}.{mode}.stderr.txt"
            if mode == "auto":
                ocr_text, stderr = ocr_image_auto(
                    image,
                    ocr_file,
                    out_dir / "images" / f"{case.id}.auto-preprocessed.png",
                    lang,
                    psm,
                )
            else:
                ocr_text, stderr = ocr_image(ocr_input, lang, psm)
            ocr_file.write_text(ocr_text, encoding="utf-8")
            stderr_file.write_text(stderr, encoding="utf-8")

            cer, wer = error_rates(case.text, ocr_text)
            route, route_info = detect_route(ocr_text, config)
            passed = cer <= case.max_cer and route == case.expected_route
            results.append(
                {
                    "case": case.id,
                    "mode": mode,
                    "image": str(ocr_input.relative_to(out_dir)),
                    "truth_file": str(truth_file.relative_to(out_dir)),
                    "ocr_file": str(ocr_file.relative_to(out_dir)),
                    "stderr_file": str(stderr_file.relative_to(out_dir)),
                    "cer": cer,
                    "wer": wer,
                    "max_cer": case.max_cer,
                    "required": case.required,
                    "route": route,
                    "expected_route": case.expected_route,
                    "route_info": route_info,
                    "passed": passed,
                    "notes": case.notes,
                    "truth_text": case.text,
                    "ocr_text": ocr_text,
                    "stderr_text": stderr,
                }
            )

    write_report(results, out_dir, lang, psm, args.mode)
    failures = [row for row in results if not row["passed"]]
    blocking_failures = [row for row in failures if row["required"]]
    challenge_failures = [row for row in failures if not row["required"]]
    print(f"OCR stress artifacts: {out_dir}")
    print(f"Report: {out_dir / 'report.md'}")
    print(f"HTML report: {out_dir / 'report.html'}")
    print(
        f"Cases: {len(results)}  Failures: {len(failures)}  "
        f"Blocking: {len(blocking_failures)}  Challenge warnings: {len(challenge_failures)}"
    )
    for row in results:
        status = "PASS" if row["passed"] else "FAIL" if row["required"] else "WARN"
        print(
            f"{status} {row['case']}[{row['mode']}]: "
            f"CER={row['cer']:.3f} WER={row['wer']:.3f} "
            f"route={row['route']} expected={row['expected_route']}"
        )
    return 1 if blocking_failures else 0


if __name__ == "__main__":
    raise SystemExit(main())
