    id: str
    text: str
    expected_route: str
    max_cer: float
    required: bool = True
    font_size: int = 30
    width: int = 1180
    fill: str = "#111111"
    background: str = "#ffffff"
    effects: tuple[str, ...] = ()
    notes: str = ""


