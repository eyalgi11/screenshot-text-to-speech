def parse_env_file(path: Path) -> dict[str, str]:
    config: dict[str, str] = {}
    if not path.exists():
        return config
    for raw in path.read_text(encoding="utf-8").splitlines():
        line = raw.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        try:
            config[key.strip()] = shlex.split(value, posix=True)[0] if value.strip() else ""
        except ValueError:
            config[key.strip()] = value.strip().strip('"').strip("'")
    return config


def available_langs() -> set[str]:
    proc = subprocess.run(["tesseract", "--list-langs"], capture_output=True, text=True, check=False)
    return {line.strip() for line in proc.stdout.splitlines()[1:] if line.strip()}


def default_ocr_lang(config: dict[str, str]) -> str:
    if config.get("STTS_OCR_LANG"):
        return config["STTS_OCR_LANG"]
    langs = available_langs()
    return "eng+heb" if {"eng", "heb"}.issubset(langs) else "eng"


def normalize(text: str) -> str:
    text = unicodedata.normalize("NFKC", text)
    text = "".join(ch for ch in text if ch not in BIDI_MARKS)
    text = text.replace("־", "-")
    text = re.sub(r"[ \t\r\f\v]+", " ", text)
    text = re.sub(r"\n\s+", "\n", text)
    text = re.sub(r"\s+\n", "\n", text)
    text = re.sub(r"\n{3,}", "\n\n", text)
    return text.strip().lower()


def levenshtein(a: list[str] | str, b: list[str] | str) -> int:
    if len(a) < len(b):
        a, b = b, a
    previous = list(range(len(b) + 1))
    for i, ca in enumerate(a, 1):
        current = [i]
        for j, cb in enumerate(b, 1):
            insert = current[j - 1] + 1
            delete = previous[j] + 1
            replace = previous[j - 1] + (ca != cb)
            current.append(min(insert, delete, replace))
        previous = current
    return previous[-1]


def error_rates(expected: str, actual: str) -> tuple[float, float]:
    expected_norm = normalize(expected)
    actual_norm = normalize(actual)
    char_den = max(len(expected_norm), 1)
    cer = levenshtein(expected_norm, actual_norm) / char_den
    expected_words = expected_norm.split()
    actual_words = actual_norm.split()
    wer = levenshtein(expected_words, actual_words) / max(len(expected_words), 1)
    return cer, wer


def word_ratio(expected: str, actual: str) -> float:
    expected_words = normalize(expected).split()
    actual_words = normalize(actual).split()
    return len(actual_words) / max(len(expected_words), 1)


def contains_phrase(text: str, phrase: str) -> bool:
    return normalize(phrase) in normalize(text)


def evaluate_case(case: Case, actual: str, cer: float, route: str) -> tuple[bool, list[str], float]:
    checks: list[str] = []
    passed = True

    cer_ok = cer <= case.max_cer
    passed = passed and cer_ok
    checks.append(f"{'PASS' if cer_ok else 'FAIL'} cer {cer:.3f} <= {case.max_cer:.3f}")

    route_ok = route == case.expected_route
    passed = passed and route_ok
    checks.append(f"{'PASS' if route_ok else 'FAIL'} route {route} == {case.expected_route}")

    ratio = word_ratio(case.text, actual)
    if case.max_word_ratio:
        ratio_ok = ratio <= case.max_word_ratio
        passed = passed and ratio_ok
        checks.append(f"{'PASS' if ratio_ok else 'FAIL'} word ratio {ratio:.2f} <= {case.max_word_ratio:.2f}")

    for phrase in case.must_include:
        phrase_ok = contains_phrase(actual, phrase)
        passed = passed and phrase_ok
        checks.append(f"{'PASS' if phrase_ok else 'FAIL'} must include: {phrase}")

    for phrase in case.must_not_include:
        phrase_ok = not contains_phrase(actual, phrase)
        passed = passed and phrase_ok
        checks.append(f"{'PASS' if phrase_ok else 'FAIL'} must not include: {phrase}")

    return passed, checks, ratio


def pango_markup(case: Case) -> str:
    escaped = html.escape(case.text)
    return f'<span font_desc="DejaVu Sans {case.font_size}">{escaped}</span>'


def run(cmd: list[str], *, input_text: str | None = None) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        cmd,
        input=input_text,
        capture_output=True,
        text=True,
        check=False,
    )


def generate_image(case: Case, path: Path) -> None:
    border_size = "44" if "camera_warp" in case.effects else "28"
    base = [
        "magick",
        "-seed",
        str(sum(ord(ch) for ch in case.id)),
        "-background",
        case.background,
        "-fill",
        case.fill,
        "-size",
        f"{case.width}x",
        f"pango:{pango_markup(case)}",
        "-bordercolor",
        case.background,
        "-border",
        border_size,
    ]
    effects: list[str] = []
    overlay_effects: list[str] = []
    post_effects: list[str] = []
    for effect in case.effects:
        if effect == "blur":
            effects.extend(["-blur", "0x0.7"])
        elif effect == "noise":
            effects.extend(["+noise", "Gaussian"])
        elif effect == "resize_75":
            effects.extend(["-resize", "75%"])
        elif effect == "resize_80":
            effects.extend(["-resize", "80%"])
        elif effect == "resize_90":
            effects.extend(["-resize", "90%"])
        elif effect == "rotate_1":
            effects.extend(["-background", case.background, "-rotate", "1"])
        elif effect in OVERLAY_EFFECTS:
            overlay_effects.append(effect)
        elif effect in POST_EFFECTS:
            post_effects.append(effect)
        else:
            raise ValueError(f"Unknown effect: {effect}")

    proc = run([*base, *effects, str(path)])
    if proc.returncode != 0:
        raise RuntimeError(f"Image generation failed for {case.id}:\n{proc.stderr}")
    for effect in overlay_effects:
        apply_overlay_effect(case, path, effect)
    for effect in post_effects:
        apply_post_effect(case, path, effect)
    strip_image_metadata(path)


def image_size(path: Path) -> tuple[int, int]:
    proc = run(["magick", "identify", "-format", "%w %h", str(path)])
    if proc.returncode != 0:
        raise RuntimeError(f"Could not inspect image size for {path}:\n{proc.stderr}")
    width, height = proc.stdout.strip().split()
    return int(width), int(height)


def draw_text_command(x: int, y: int, text: str) -> str:
    safe = text.replace("\\", "\\\\").replace("'", "\\'")
    return f"text {x},{y} '{safe}'"


def apply_overlay_effect(case: Case, path: Path, effect: str) -> None:
    width, height = image_size(path)
    rng = random.Random(f"{case.id}:{effect}")
    args: list[str] = []

    if effect == "thin_rules":
        args.extend(["-stroke", "#d2d6cf", "-strokewidth", "1", "-fill", "none"])
        for _ in range(5):
            y = rng.randint(18, max(20, height - 18))
            args.extend(["-draw", f"line 12,{y} {max(24, width - 12)},{y}"])
        for _ in range(4):
            x = rng.randint(20, max(24, width - 20))
            args.extend(["-draw", f"line {x},10 {x},{max(20, height - 10)}"])
        for _ in range(3):
            x1 = rng.randint(8, max(10, width // 3))
            y1 = rng.randint(8, max(10, height // 2))
            x2 = min(width - 8, x1 + rng.randint(60, 180))
            y2 = min(height - 8, y1 + rng.randint(22, 58))
            args.extend(["-draw", f"rectangle {x1},{y1} {x2},{y2}"])

    elif effect == "barcode_blocks":
        anchor_left = case.expected_route == "hebrew"
        x1 = 18 if anchor_left else max(18, width - 190)
        y1 = rng.randint(16, max(18, min(height - 72, height // 2)))
        args.extend(["-fill", "#f9f9f4", "-stroke", "#d7d7cf", "-strokewidth", "1"])
        args.extend(["-draw", f"rectangle {x1},{y1} {x1 + 142},{y1 + 52}"])
        args.extend(["-fill", "#2d3133", "-stroke", "none"])
        x = x1 + 8
        while x < x1 + 132:
            line_width = rng.randint(1, 4)
            gap = rng.randint(2, 6)
            args.extend(["-draw", f"rectangle {x},{y1 + 7} {x + line_width},{y1 + 45}"])
            x += line_width + gap

        qr_size = 72
        qr_x = 18 if anchor_left else max(18, width - qr_size - 24)
        qr_y = rng.randint(max(18, height - qr_size - 28), max(20, height - qr_size - 10))
        cell = 6
        args.extend(["-fill", "#fbfbf8", "-stroke", "#d7d7cf", "-strokewidth", "1"])
        args.extend(["-draw", f"rectangle {qr_x},{qr_y} {qr_x + qr_size},{qr_y + qr_size}"])
        args.extend(["-fill", "#323638", "-stroke", "none"])
        for row in range(10):
            for col in range(10):
                in_corner = (row < 3 and col < 3) or (row < 3 and col > 6) or (row > 6 and col < 3)
                if in_corner or rng.random() < 0.36:
                    bx = qr_x + 6 + col * cell
                    by = qr_y + 6 + row * cell
                    args.extend(["-draw", f"rectangle {bx},{by} {bx + 4},{by + 4}"])

    elif effect == "chart_distractors":
        chart_x = max(20, width - 330)
        chart_y = rng.randint(14, max(16, min(height - 118, height // 2)))
        chart_w = min(290, max(120, width - chart_x - 16))
        chart_h = min(110, max(60, height - chart_y - 16))
        args.extend(["-fill", "#edf4f2", "-stroke", "#c6d4d1", "-strokewidth", "1"])
        args.extend(["-draw", f"roundrectangle {chart_x},{chart_y} {chart_x + chart_w},{chart_y + chart_h} 8,8"])
        args.extend(["-stroke", "#d4dedb", "-strokewidth", "1", "-fill", "none"])
        for i in range(1, 4):
            y = chart_y + i * chart_h // 4
            args.extend(["-draw", f"line {chart_x + 10},{y} {chart_x + chart_w - 10},{y}"])
        bar_w = max(9, chart_w // 12)
        args.extend(["-fill", "#94b7c2", "-stroke", "none"])
        for i in range(6):
            bx = chart_x + 18 + i * (bar_w + 8)
            bh = rng.randint(chart_h // 5, max(chart_h // 5 + 1, chart_h - 28))
            args.extend(["-draw", f"rectangle {bx},{chart_y + chart_h - 12 - bh} {bx + bar_w},{chart_y + chart_h - 12}"])
        points = []
        for i in range(6):
            px = chart_x + 18 + i * max(18, (chart_w - 40) // 5)
            py = chart_y + 16 + rng.randint(0, max(1, chart_h - 40))
            points.append((px, py))
        args.extend(["-stroke", "#d48f75", "-strokewidth", "3", "-fill", "none"])
        for (x_a, y_a), (x_b, y_b) in zip(points, points[1:]):
            args.extend(["-draw", f"line {x_a},{y_a} {x_b},{y_b}"])
        args.extend(["-fill", "#d48f75", "-stroke", "none"])
        for px, py in points:
            args.extend(["-draw", f"circle {px},{py} {px + 3},{py}"])

    elif effect == "graphic_card_shapes":
        anchor_left = case.expected_route == "hebrew"
        for _ in range(3):
            card_w = rng.randint(72, 126)
            card_h = rng.randint(42, 76)
            if anchor_left:
                x1 = rng.randint(8, min(90, max(8, width - card_w - 8)))
            else:
                x1 = rng.randint(max(8, width - card_w - 120), max(8, width - card_w - 8))
            y1 = rng.randint(10, max(12, height - card_h - 8))
            x2 = min(width - 8, x1 + card_w)
            y2 = min(height - 8, y1 + card_h)
            args.extend(["-fill", "#eef2f6", "-stroke", "#ccd4dc", "-strokewidth", "1"])
            args.extend(["-draw", f"roundrectangle {x1},{y1} {x2},{y2} 9,9"])
            args.extend(["-fill", "#cad8e6", "-stroke", "none"])
            args.extend(["-draw", f"circle {x1 + 18},{y1 + 18} {x1 + 28},{y1 + 18}"])
            args.extend(["-fill", "#aebfd0"])
            args.extend(["-draw", f"polygon {x1 + 10},{y2 - 10} {x1 + 42},{y1 + 30} {x1 + 66},{y2 - 10}"])
            args.extend(["-fill", "#d7e3bc"])
            args.extend(["-draw", f"polygon {x1 + 44},{y2 - 10} {x1 + 84},{y1 + 26} {x2 - 10},{y2 - 10}"])

    elif effect == "icon_doodles":
        anchor_left = case.expected_route == "hebrew"
        args.extend(["-stroke", "#a9b5bd", "-strokewidth", "3", "-fill", "none"])
        for _ in range(3):
            if anchor_left:
                x = rng.randint(24, min(110, max(24, width - 46)))
            else:
                x = rng.randint(max(24, width - 150), max(24, width - 46))
            y = rng.randint(24, max(28, height - 44))
            args.extend(["-draw", f"circle {x},{y} {x + 16},{y}"])
            args.extend(["-draw", f"line {x - 12},{y + 20} {x + 12},{y + 20}"])
        if anchor_left:
            x = rng.randint(18, min(120, max(18, width - 70)))
        else:
            x = rng.randint(max(18, width - 190), max(18, width - 70))
        y = rng.choice([rng.randint(18, 42), rng.randint(max(22, height - 54), max(24, height - 22))])
        args.extend(["-stroke", "#c9a96b", "-strokewidth", "3", "-fill", "none"])
        args.extend(["-draw", f"polygon {x},{y + 34} {x + 24},{y} {x + 48},{y + 34}"])
        args.extend(["-draw", f"line {x + 24},{y + 10} {x + 24},{y + 23}"])
        args.extend(["-draw", f"circle {x + 24},{y + 29} {x + 26},{y + 29}"])
        path_points = []
        if anchor_left:
            start_x = rng.randint(24, min(130, max(24, width - 260)))
        else:
            start_x = rng.randint(max(24, width - 260), max(26, width - 190))
        base_y = rng.randint(max(24, height - 74), max(26, height - 34))
        for i in range(5):
            path_points.append((start_x + i * rng.randint(34, 54), base_y + rng.randint(-18, 18)))
        args.extend(["-stroke", "#9db7a2", "-strokewidth", "4", "-fill", "none"])
        for (x_a, y_a), (x_b, y_b) in zip(path_points, path_points[1:]):
            args.extend(["-draw", f"line {x_a},{y_a} {x_b},{y_b}"])

    elif effect == "edge_badges":
        tokens = ["OK", "?", "x", "!", "::", "copy", "tap", "ID", "#", "⋯"]
        args.extend(["-font", "DejaVu-Sans", "-fill", "#9aa19a"])
        for _ in range(8):
            token = rng.choice(tokens)
            size = rng.randint(12, 20)
            x1 = rng.choice([rng.randint(8, 110), rng.randint(max(12, width - 150), max(14, width - 55))])
            y1 = rng.randint(12, max(18, height - 34))
            x2 = min(width - 8, x1 + rng.randint(34, 84))
            y2 = min(height - 8, y1 + rng.randint(20, 34))
            args.extend(
                [
                    "-fill",
                    "#e7ebe4",
                    "-stroke",
                    "#c8cec4",
                    "-strokewidth",
                    "1",
                    "-draw",
                    f"roundrectangle {x1},{y1} {x2},{y2} 6,6",
                    "-stroke",
                    "none",
                    "-fill",
                    "#8b918a",
                    "-pointsize",
                    str(size),
                    "-draw",
                    draw_text_command(x1 + 8, y1 + size + 2, token),
                ]
            )

    elif effect == "ui_symbol_distractors":
        tokens = ["[ ]", "[x]", "::", "||", "!!", "?", "#", "@", "0O", "1lI", "<>", "/\\", "++", "--"]
        args.extend(["-font", "DejaVu-Sans", "-fill", "#8b918a"])
        for _ in range(14):
            token = rng.choice(tokens)
            size = rng.randint(13, 24)
            if rng.random() < 0.55:
                x = rng.choice([rng.randint(6, 80), rng.randint(max(8, width - 130), max(10, width - 45))])
                y = rng.randint(18, max(20, height - 8))
            else:
                x = rng.randint(6, max(8, width - 70))
                y = rng.choice([rng.randint(16, 36), rng.randint(max(20, height - 34), max(22, height - 8))])
            args.extend(["-pointsize", str(size), "-draw", draw_text_command(x, y, token)])

    elif effect == "watermark_symbols":
        tokens = ["@", "#", "?", "0O", "I1", "<>", "[]", "||", "⋯", "₪", "%"]
        args.extend(["-font", "DejaVu-Sans", "-fill", "#a8ada6"])
        for _ in range(10):
            token = rng.choice(tokens)
            size = rng.randint(26, 58)
            x = rng.randint(4, max(8, width - 92))
            y = rng.randint(30, max(34, height - 8))
            args.extend(["-pointsize", str(size), "-draw", draw_text_command(x, y, token)])

    elif effect == "math_symbol_distractors":
        tokens = ["+", "-", "*", "/", "=", "!=", "<=", ">=", "~=", "()", "[]", "{}", "x2", "O0", "l1", "..."]
        args.extend(["-font", "DejaVu-Sans", "-fill", "#858585"])
        for _ in range(20):
            token = rng.choice(tokens)
            size = rng.randint(12, 22)
            if rng.random() < 0.5:
                x = rng.choice([rng.randint(8, 90), rng.randint(max(10, width - 120), max(12, width - 45))])
                y = rng.randint(18, max(20, height - 8))
            else:
                x = rng.randint(8, max(10, width - 60))
                y = rng.choice([rng.randint(18, 42), rng.randint(max(20, height - 40), max(22, height - 8))])
            args.extend(["-pointsize", str(size), "-draw", draw_text_command(x, y, token)])

    else:
        raise ValueError(f"Unknown overlay effect: {effect}")

    tmp = path.with_suffix(f".{effect}.png")
    proc = run(["magick", str(path), *args, str(tmp)])
    if proc.returncode != 0:
        raise RuntimeError(f"Overlay effect {effect} failed for {case.id}:\n{proc.stderr}")
    tmp.replace(path)


def apply_post_effect(case: Case, path: Path, effect: str) -> None:
    width, height = image_size(path)
    tmp = path.with_suffix(f".{effect}.png")

    if effect == "paper_texture":
        seed = str(sum(ord(ch) for ch in f"{case.id}:{effect}"))
        proc = run(
            [
                "magick",
                "-seed",
                seed,
                str(path),
                "-attenuate",
                "0.10",
                "+noise",
                "Gaussian",
                "-brightness-contrast",
                "1x4",
                str(tmp),
            ]
        )

    elif effect == "camera_warp":
        points = (
            f"0,0 8,6 "
            f"{width},0 {max(0, width - 10)},11 "
            f"0,{height} 12,{max(0, height - 6)} "
            f"{width},{height} {max(0, width - 15)},{max(0, height - 3)}"
        )
        proc = run(
            [
                "magick",
                str(path),
                "-virtual-pixel",
                "edge",
                "-distort",
                "Perspective",
                points,
                "+repage",
                "-blur",
                "0x0.25",
                str(tmp),
            ]
        )

    elif effect == "jpeg_artifacts":
        jpg = path.with_suffix(".jpeg-artifacts.jpg")
        proc = run(["magick", str(path), "-quality", "38", str(jpg)])
        if proc.returncode == 0:
            proc = run(["magick", str(jpg), str(tmp)])
        if jpg.exists():
            jpg.unlink()

    else:
        raise ValueError(f"Unknown post effect: {effect}")

    if proc.returncode != 0:
        raise RuntimeError(f"Post effect {effect} failed for {case.id}:\n{proc.stderr}")
    tmp.replace(path)


def strip_image_metadata(path: Path) -> None:
    tmp = path.with_suffix(".stripped.png")
    proc = run(["magick", str(path), "-strip", "-define", "png:exclude-chunk=all", str(tmp)])
    if proc.returncode != 0:
        raise RuntimeError(f"Could not strip image metadata for {path}:\n{proc.stderr}")
    tmp.replace(path)


def preprocess_image(input_path: Path, output_path: Path) -> None:
    proc = run(
        [
            "magick",
            str(input_path),
            "-colorspace",
            "Gray",
            "-resize",
            "200%",
            "-sigmoidal-contrast",
            "8x50%",
            "-sharpen",
            "0x1",
            str(output_path),
        ]
    )
    if proc.returncode != 0:
        raise RuntimeError(f"Preprocess failed for {input_path}:\n{proc.stderr}")


def ocr_image(path: Path, lang: str, psm: str) -> tuple[str, str]:
    proc = run(["tesseract", str(path), "stdout", "-l", lang, "--psm", psm])
    return proc.stdout, proc.stderr


def ocr_image_auto(path: Path, output_path: Path, preprocessed_path: Path, lang: str, psm: str) -> tuple[str, str]:
    proc = run(
        [
            sys.executable,
            str(PROJECT_DIR / "bin" / "ocr-image"),
            "--image",
            str(path),
            "--output",
            str(output_path),
            "--lang",
            lang,
            "--psm",
            psm,
            "--preprocess",
            "auto",
            "--preprocessed-image",
            str(preprocessed_path),
        ]
    )
    text = output_path.read_text(encoding="utf-8") if output_path.exists() else ""
    return text, proc.stderr


def detect_route(text: str, config: dict[str, str]) -> tuple[str, dict[str, str]]:
    threshold = config.get("STTS_HEBREW_ROUTE_THRESHOLD", "0.35")
    min_chars = config.get("STTS_HEBREW_ROUTE_MIN_CHARS", "3")
    proc = run(
        [
            sys.executable,
            str(PROJECT_DIR / "bin" / "detect-text-language"),
            "--hebrew-threshold",
            threshold,
            "--hebrew-min-chars",
            min_chars,
        ],
        input_text=text,
    )
    parsed: dict[str, str] = {}
    for line in proc.stdout.splitlines():
        if "=" in line:
            key, value = line.split("=", 1)
            parsed[key] = value
    return parsed.get("route", "unknown"), parsed


def write_markdown_report(results: list[dict[str, object]], out_dir: Path, lang: str, psm: str, mode: str) -> None:
    failures = [row for row in results if not row["passed"]]
    blocking_failures = [row for row in failures if row["required"]]
    challenge_failures = [row for row in failures if not row["required"]]
    lines = [
        "# OCR Stress Report",
        "",
        f"- Generated: {time.strftime('%Y-%m-%d %H:%M:%S %Z')}",
        f"- OCR language: `{lang}`",
        f"- Tesseract PSM: `{psm}`",
        f"- Mode: `{mode}`",
        f"- Cases: {len(results)}",
        f"- Failures: {len(failures)}",
        f"- Blocking failures: {len(blocking_failures)}",
        f"- Challenge failures: {len(challenge_failures)}",
        "",
        "| Order | Case | Tier | Mode | CER | WER | Route | Expected Route | Result | Notes |",
        "| ---: | --- | --- | --- | ---: | ---: | --- | --- | --- | --- |",
    ]
    for row in results:
        tier = "required" if row["required"] else "challenge"
        result = "pass" if row["passed"] else "FAIL" if row["required"] else "CHALLENGE_FAIL"
        lines.append(
            "| {case_order} | {case} | {tier} | {mode} | {cer:.3f} | {wer:.3f} | {route} | {expected_route} | {result} | {notes} |".format(
                case_order=row["case_order"],
                case=row["case"],
                tier=tier,
                mode=row["mode"],
                cer=row["cer"],
                wer=row["wer"],
                route=row["route"],
                expected_route=row["expected_route"],
                result=result,
                notes=str(row["notes"]).replace("|", "\\|"),
            )
        )
    lines.append("")
    lines.append("## OCR Text")
    for row in results:
        lines.extend(
            [
                "",
                f"### {row['case']} ({row['mode']})",
                "",
                f"- Image: `{row['image']}`",
                f"- Ground truth: `{row['truth_file']}`",
                f"- OCR file: `{row['ocr_file']}`",
                f"- OCR stderr: `{row['stderr_file']}`",
                f"- Word ratio: {float(row['word_ratio']):.2f}",
                "",
                "Checks:",
                "",
                "```text",
                "\n".join(str(check) for check in row["checks"]),
                "```",
                "",
                "```text",
                str(row["ocr_text"]).strip(),
                "```",
            ]
        )
    (out_dir / "report.md").write_text("\n".join(lines) + "\n", encoding="utf-8")


def write_html_report(results: list[dict[str, object]], out_dir: Path, lang: str, psm: str, mode: str) -> None:
    failures = [row for row in results if not row["passed"]]
    blocking_failures = [row for row in failures if row["required"]]
    challenge_failures = [row for row in failures if not row["required"]]

    def esc(value: object) -> str:
        return html.escape(str(value), quote=True)

    def status_class(row: dict[str, object]) -> str:
        if row["passed"]:
            return "pass"
        return "fail" if row["required"] else "challenge-fail"

    def status_label(row: dict[str, object]) -> str:
        if row["passed"]:
            return "pass"
        return "fail" if row["required"] else "challenge fail"

    def image_data_uri(row: dict[str, object]) -> str:
        image_path = out_dir / str(row["image"])
        encoded = base64.b64encode(image_path.read_bytes()).decode("ascii")
        return f"data:image/png;base64,{encoded}"

    summary_rows = []
    for row in results:
        row_status = status_class(row)
        row_label = status_label(row)
        summary_rows.append(
            f"<tr data-case-order=\"{esc(row['case_order'])}\" data-run-order=\"{esc(row['run_order'])}\">"
            f"<td class=\"num\">{int(row['case_order'])}</td>"
            f"<td><a href=\"#{esc(row['case'])}-{esc(row['mode'])}\">{esc(row['case'])}</a></td>"
            f"<td>{'required' if row['required'] else 'challenge'}</td>"
            f"<td>{esc(row['mode'])}</td>"
            f"<td class=\"num\">{float(row['cer']):.3f}</td>"
            f"<td class=\"num\">{float(row['wer']):.3f}</td>"
            f"<td>{esc(row['route'])}</td>"
            f"<td>{esc(row['expected_route'])}</td>"
            f"<td><span class=\"pill {row_status}\">{row_label}</span></td>"
            "</tr>"
        )

    detail_cards = []
    for row in results:
        row_status = status_class(row)
        row_label = status_label(row)
        checks_text = "\n".join(str(check) for check in row["checks"])
        detail_cards.append(
            f"<section class=\"case\" id=\"{esc(row['case'])}-{esc(row['mode'])}\" data-case-order=\"{esc(row['case_order'])}\" data-run-order=\"{esc(row['run_order'])}\">"
            "<div class=\"case-head\">"
            "<div>"
            f"<h2>{esc(row['case'])}</h2>"
            f"<p>{esc(row['notes'])}</p>"
            "</div>"
            f"<span class=\"pill {row_status}\">{row_label}</span>"
            "</div>"
            "<div class=\"metrics\">"
            f"<div><span>CER</span><b>{float(row['cer']):.3f}</b><small>limit {float(row['max_cer']):.3f}</small></div>"
            f"<div><span>WER</span><b>{float(row['wer']):.3f}</b></div>"
            f"<div><span>Word Ratio</span><b>{float(row['word_ratio']):.2f}</b><small>{'limit ' + format(float(row['max_word_ratio']), '.2f') if row['max_word_ratio'] else 'no limit'}</small></div>"
            f"<div><span>Route</span><b>{esc(row['route'])}</b><small>expected {esc(row['expected_route'])}</small></div>"
            f"<div><span>Mode</span><b>{esc(row['mode'])}</b></div>"
            f"<div><span>Tier</span><b>{'required' if row['required'] else 'challenge'}</b></div>"
            f"<div><span>Order</span><b>{int(row['case_order'])}</b><small>oldest first</small></div>"
            "</div>"
            "<div class=\"inspect-grid\">"
            "<figure>"
            f"<img src=\"{image_data_uri(row)}\" alt=\"Generated OCR test image for {esc(row['case'])}\">"
            f"<figcaption>Generated image: {esc(row['image'])}</figcaption>"
            "</figure>"
            "<div class=\"text-pair\">"
            "<div>"
            "<h3>Ground Truth</h3>"
            f"<pre dir=\"auto\">{esc(row['truth_text'])}</pre>"
            "</div>"
            "<div>"
            "<h3>OCR Output</h3>"
            f"<pre dir=\"auto\">{esc(row['ocr_text']).strip()}</pre>"
            "</div>"
            "</div>"
            "</div>"
            "<details>"
            "<summary>Route and OCR diagnostics</summary>"
            f"<pre>{esc(checks_text)}</pre>"
            f"<pre>{esc(json.dumps(row['route_info'], indent=2, ensure_ascii=False))}</pre>"
            f"<pre>{esc(row['stderr_text']).strip()}</pre>"
            "</details>"
            "</section>"
        )

    html_text = f"""<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>OCR Stress Report</title>
  <style>
    :root {{
      color-scheme: light;
      --bg: #f5f6f2;
      --panel: #ffffff;
      --ink: #1f2328;
      --muted: #5d6773;
      --line: #d8ddd2;
      --pass: #12633f;
      --pass-bg: #dff3e8;
      --warn: #8a5a00;
      --warn-bg: #fff1c7;
      --challenge-fail: #7c4a03;
      --challenge-fail-bg: #ffe2a8;
      --fail: #9e2b25;
      --fail-bg: #f8dfdc;
      --accent: #365f91;
    }}
    * {{ box-sizing: border-box; }}
    body {{
      margin: 0;
      background: var(--bg);
      color: var(--ink);
      font: 15px/1.45 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }}
    main {{
      width: min(1180px, calc(100% - 32px));
      margin: 0 auto;
      padding: 28px 0 44px;
    }}
    header {{
      margin-bottom: 22px;
    }}
    h1 {{
      margin: 0 0 8px;
      font-size: 30px;
      letter-spacing: 0;
    }}
    h2 {{
      margin: 0;
      font-size: 20px;
      letter-spacing: 0;
    }}
    h3 {{
      margin: 0 0 8px;
      font-size: 14px;
      letter-spacing: 0;
    }}
    p {{ margin: 0; color: var(--muted); }}
    .overview {{
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 10px;
      margin: 18px 0;
    }}
    .stat, .case {{
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 8px;
    }}
    .stat {{
      padding: 12px;
    }}
    .stat span {{
      display: block;
      color: var(--muted);
      font-size: 12px;
    }}
    .stat b {{
      display: block;
      margin-top: 4px;
      font-size: 24px;
    }}
    .table-wrap {{
      overflow-x: auto;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--panel);
      margin-bottom: 18px;
    }}
    .report-controls {{
      position: sticky;
      top: 0;
      z-index: 20;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 12px;
      margin: 0 0 12px;
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.96);
