#!/usr/bin/env bash
set -Eeuo pipefail

PROJECT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
cd "$PROJECT_DIR"

shell_files=(
  bin/screenshot-read
  bin/session-hotkey-service
  scripts/install-wayland-evdev-daemon
  scripts/check-portable
  scripts/check-system
  scripts/disable-kde-shortcut-grab
  scripts/install
  scripts/install-desktop-integration
  scripts/install-kde-shortcut
  scripts/install-pause-daemon
  scripts/install-system-deps
  scripts/record-reference-voice
  scripts/setup-hebrew-blue
  scripts/setup-omnivoice
  scripts/uninstall
)

for file in "${shell_files[@]}"; do
  bash -n "$file"
done

python3 -m py_compile bin/blue-hebrew-say bin/detect-text-language bin/ocr-image bin/ocr-quality-gate bin/omnivoice-say bin/pause-hotkey-daemon bin/wayland-pause-evdev-daemon scripts/ocr-bakeoff scripts/stress-ocr
python3 - <<'PY'
import runpy

blue = runpy.run_path("bin/blue-hebrew-say")
strip_language_tags = blue["strip_language_tags"]
assert strip_language_tags("<he>shalom</he>") == "shalom"
assert strip_language_tags("<he>foo</he> <en>bar</en>") == "foo bar"
PY

printf 'Hello world' | bin/ocr-quality-gate >/dev/null
if printf '@@@@' | bin/ocr-quality-gate >/dev/null; then
  echo "OCR quality gate did not block junk text." >&2
  exit 1
fi

hebrew_detection="$(printf 'שלום עולם' | bin/detect-text-language)"
printf '%s\n' "$hebrew_detection" | grep -F 'route=hebrew' >/dev/null
english_detection="$(printf 'Hello world' | bin/detect-text-language)"
printf '%s\n' "$english_detection" | grep -F 'route=default' >/dev/null

forbidden_homes=("${STTS_PORTABLE_FORBIDDEN_HOME:-/home/${STTS_PORTABLE_FORBIDDEN_USER:-eyal}}")
if [[ -n "${HOME:-}" && "$HOME" != "${forbidden_homes[0]}" ]]; then
  forbidden_homes+=("$HOME")
fi

for home_path in "${forbidden_homes[@]}"; do
  if command -v rg >/dev/null 2>&1; then
    hardcoded_home="$(rg -n -F "$home_path" . \
      --glob '!config/screenshot-tts.env' \
      --glob '!voices/**' \
      --glob '!.venv/**' \
      --glob '!.git/**' \
      --glob '!.agents/**' \
      --glob '!.codex/**' || true)"
  else
    hardcoded_home="$(grep -RInF --exclude-dir=.venv --exclude-dir=.git --exclude-dir=.agents --exclude-dir=.codex --exclude-dir=voices --exclude=screenshot-tts.env "$home_path" . || true)"
  fi

  if [[ -n "$hardcoded_home" ]]; then
    printf 'Found hardcoded local home paths outside ignored local files:\n%s\n' "$hardcoded_home" >&2
    exit 1
  fi
done

tmpdir="$(mktemp -d)"
trap 'rm -rf -- "$tmpdir"' EXIT

XDG_DATA_HOME="$tmpdir/data" \
XDG_CONFIG_HOME="$tmpdir/config" \
XDG_STATE_HOME="$tmpdir/state" \
STTS_SESSION_TYPE=wayland \
STTS_HOTKEY_SERVICE_ONESHOT=1 \
STTS_KDE_SKIP_LIVE=1 \
  bin/session-hotkey-service

desktop_file="$tmpdir/data/applications/io.github.eyal.screenshot-text-to-speech.desktop"
grep -F "Exec=$PROJECT_DIR/bin/screenshot-read --toggle" "$desktop_file" >/dev/null
grep -F "X-KDE-Shortcuts=Pause" "$desktop_file" >/dev/null

printf 'X-KDE-Shortcuts=Pause\n' >>"$desktop_file"
XDG_DATA_HOME="$tmpdir/data" \
XDG_CONFIG_HOME="$tmpdir/config" \
XDG_STATE_HOME="$tmpdir/state" \
STTS_SESSION_TYPE=x11 \
STTS_HOTKEY_SERVICE_ONESHOT=1 \
  bin/session-hotkey-service

if grep -F "X-KDE-Shortcuts=Pause" "$desktop_file" >/dev/null; then
  echo "X11 integration did not remove the KDE Pause shortcut grab." >&2
  exit 1
fi

echo "Portable checks passed."
