#!/usr/bin/env bash
set -Eeuo pipefail

PROJECT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
SERVICE_NAME="screenshot-text-to-speech-pause.service"
USER_SYSTEMD_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
DESKTOP_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/applications/io.github.eyal.screenshot-text-to-speech.desktop"
REMOVE_VENV=0
REMOVE_CONFIG=0
REMOVE_STATE=0

usage() {
  cat <<'EOF'
Usage: scripts/uninstall [--remove-venv] [--remove-config] [--remove-state]

Remove the user-level hotkey service and KDE launcher created by this project.
The Python environment, local config, logs, and reference voices are kept unless
you explicitly remove them with options.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --remove-venv) REMOVE_VENV=1 ;;
    --remove-config) REMOVE_CONFIG=1 ;;
    --remove-state) REMOVE_STATE=1 ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

if command -v systemctl >/dev/null 2>&1; then
  systemctl --user disable --now "$SERVICE_NAME" >/dev/null 2>&1 || true
  rm -f -- "$USER_SYSTEMD_DIR/$SERVICE_NAME"
  systemctl --user daemon-reload >/dev/null 2>&1 || true
fi

rm -f -- "$DESKTOP_FILE"
if command -v kbuildsycoca6 >/dev/null 2>&1; then
  kbuildsycoca6 >/dev/null 2>&1 || true
fi

if [[ "$REMOVE_VENV" == "1" ]]; then
  rm -rf -- "$PROJECT_DIR/.venv"
fi
if [[ "$REMOVE_CONFIG" == "1" ]]; then
  rm -f -- "$PROJECT_DIR/config/screenshot-tts.env"
fi
if [[ "$REMOVE_STATE" == "1" ]]; then
  rm -rf -- "${XDG_STATE_HOME:-$HOME/.local/state}/screenshot-text-to-speech"
fi

echo "Uninstall complete."
