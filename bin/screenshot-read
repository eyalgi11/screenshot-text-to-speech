#!/usr/bin/env bash
set -Eeuo pipefail

PROJECT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
PROJECT_CONFIG="$PROJECT_DIR/config/screenshot-tts.env"
USER_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/screenshot-text-to-speech/env"

if [[ -r "$PROJECT_CONFIG" ]]; then
  # shellcheck disable=SC1090
  source "$PROJECT_CONFIG"
fi
if [[ -r "$USER_CONFIG" ]]; then
  # shellcheck disable=SC1090
  source "$USER_CONFIG"
fi

RUN_DIR="${XDG_RUNTIME_DIR:-/tmp}/screenshot-text-to-speech"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/screenshot-text-to-speech"
mkdir -p "$RUN_DIR" "$STATE_DIR"
chmod 700 "$RUN_DIR" "$STATE_DIR" 2>/dev/null || true

LOG_FILE="$STATE_DIR/screenshot-read.log"
exec 3>>"$LOG_FILE"
FAILED=0
ACTIVE_PID_FILE="$RUN_DIR/active.pid"
ACTIVE_PGID_FILE="$RUN_DIR/active.pgid"

log() {
  printf '%s %s\n' "$(date '+%F %T')" "$*" >&3
}

notify() {
  local message="$1"
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "Screenshot Text To Speech" "$message" >/dev/null 2>&1 &
  elif command -v kdialog >/dev/null 2>&1; then
    if command -v timeout >/dev/null 2>&1; then
      timeout 3s kdialog --passivepopup "$message" 5 >/dev/null 2>&1 &
    else
      kdialog --passivepopup "$message" 5 >/dev/null 2>&1 &
    fi
  fi
}

die() {
  FAILED=1
  log "ERROR: $*"
  notify "$*"
  exit 1
}

need() {
  command -v "$1" >/dev/null 2>&1 || die "Missing command: $1"
}

clear_active_state() {
  rm -f -- "$ACTIVE_PID_FILE" "$ACTIVE_PGID_FILE"
}

read_file() {
  local path="$1"
  [[ -r "$path" ]] || return 1
  head -n 1 "$path" 2>/dev/null || return 1
}

is_pid_running() {
  local pid="$1"
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

active_pid() {
  local pid
  pid="$(read_file "$ACTIVE_PID_FILE" || true)"
  if is_pid_running "$pid"; then
    printf '%s\n' "$pid"
    return 0
  fi
  clear_active_state
  return 1
}

cancel_running() {
  local pid pgid current_pgid use_group=0
  pid="$(active_pid || true)"
  if [[ -z "$pid" ]]; then
    log "Cancel requested, but no active run exists"
    return 1
  fi

  pgid="$(read_file "$ACTIVE_PGID_FILE" || true)"
  current_pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d '[:space:]' || true)"
  if [[ "$pgid" =~ ^[0-9]+$ && "$pgid" == "$current_pgid" && "$pgid" == "$pid" ]]; then
    use_group=1
  fi

  log "Cancel requested for pid=$pid pgid=${pgid:-none}"
  notify "Stopping screen reader."

  if [[ "$use_group" == "1" ]]; then
    kill -TERM -- "-$pgid" 2>/dev/null || true
  else
    kill -TERM "$pid" 2>/dev/null || true
  fi

  for _ in $(seq 1 25); do
    is_pid_running "$pid" || break
    sleep 0.1
  done

  if is_pid_running "$pid"; then
    log "Cancel escalation for pid=$pid"
    if [[ "$use_group" == "1" ]]; then
      kill -KILL -- "-$pgid" 2>/dev/null || true
    else
      kill -KILL "$pid" 2>/dev/null || true
    fi
  fi

  clear_active_state
  return 0
}

case "${1:-}" in
  --cancel|cancel)
    cancel_running || notify "No screen reader is running."
    exit 0
    ;;
  --toggle|toggle)
    if cancel_running; then
      exit 0
    fi
    ;;
  ""|run)
    ;;
  *)
    printf 'Usage: %s [--toggle|--cancel]\n' "$0" >&2
    exit 2
    ;;
esac

SPECTACLE="${STTS_SPECTACLE:-spectacle}"
TESSERACT="${STTS_TESSERACT:-tesseract}"
PLAYER="${STTS_PLAYER:-pw-play}"
OCR_LANG="${STTS_OCR_LANG:-eng}"
OCR_PSM="${STTS_OCR_PSM:-6}"
MODEL="${STTS_OMNIVOICE_MODEL:-k2-fsa/OmniVoice}"
DEVICE="${STTS_OMNIVOICE_DEVICE:-}"
LANGUAGE="${STTS_OMNIVOICE_LANGUAGE:-}"
SPEED="${STTS_OMNIVOICE_SPEED:-1.0}"
NUM_STEP="${STTS_OMNIVOICE_NUM_STEP:-32}"
REF_AUDIO="${STTS_REF_AUDIO:-}"
REF_TEXT="${STTS_REF_TEXT:-}"
REF_TEXT_FILE="${STTS_REF_TEXT_FILE:-}"
KEEP_ARTIFACTS="${STTS_KEEP_ARTIFACTS:-0}"
HEBREW_TTS_ENGINE="${STTS_HEBREW_TTS_ENGINE:-auto}"
HEBREW_ROUTE_THRESHOLD="${STTS_HEBREW_ROUTE_THRESHOLD:-0.35}"
HEBREW_ROUTE_MIN_CHARS="${STTS_HEBREW_ROUTE_MIN_CHARS:-3}"
BLUE_ONNX_DIR="${STTS_BLUE_ONNX_DIR:-$PROJECT_DIR/models/blue-onnx-v2}"
BLUE_STYLE_JSON="${STTS_BLUE_STYLE_JSON:-$PROJECT_DIR/models/blue-voices/female1.json}"
BLUE_RENIKUD_MODEL="${STTS_BLUE_RENIKUD_MODEL:-$PROJECT_DIR/models/renikud/model.onnx}"
BLUE_LANGUAGE="${STTS_BLUE_LANGUAGE:-he}"
BLUE_PYTHON="${STTS_BLUE_PYTHON:-$PROJECT_DIR/.venv-blue/bin/python}"
BLUE_SPEED="${STTS_BLUE_SPEED:-1.05}"
BLUE_TOTAL_STEP="${STTS_BLUE_TOTAL_STEP:-16}"
BLUE_MAX_CHUNK_CHARS="${STTS_BLUE_MAX_CHUNK_CHARS:-80}"
BLUE_CHUNK_GAP_MS="${STTS_BLUE_CHUNK_GAP_MS:-180}"

need "$SPECTACLE"
need "$TESSERACT"
need "$PLAYER"
need flock

PYTHON="$PROJECT_DIR/.venv/bin/python"
if [[ ! -x "$PYTHON" ]]; then
  PYTHON="$(command -v python3 || true)"
fi
[[ -n "$PYTHON" && -x "$PYTHON" ]] || die "Missing Python. Run scripts/setup-omnivoice first."

blue_ready() {
  [[ -x "$BLUE_PYTHON" ]] || return 1
  [[ -d "$BLUE_ONNX_DIR" ]] || return 1
  [[ -r "$BLUE_STYLE_JSON" ]] || return 1
  [[ -r "$BLUE_RENIKUD_MODEL" ]] || return 1
  "$BLUE_PYTHON" -c 'import blue_onnx' >/dev/null 2>&1
}

detect_text_route() {
  local report key value
  tts_route="default"
  hebrew_chars="0"
  letter_chars="0"
  hebrew_ratio="0.000"

  if ! report="$(printf '%s' "$text" | "$PYTHON" "$PROJECT_DIR/bin/detect-text-language" \
    --hebrew-threshold "$HEBREW_ROUTE_THRESHOLD" \
    --hebrew-min-chars "$HEBREW_ROUTE_MIN_CHARS" 2>>"$LOG_FILE")"; then
    log "Language detection failed; using default TTS route"
    return 0
  fi

  while IFS='=' read -r key value; do
    case "$key" in
      route) tts_route="$value" ;;
      hebrew_chars) hebrew_chars="$value" ;;
      letter_chars) letter_chars="$value" ;;
      hebrew_ratio) hebrew_ratio="$value" ;;
    esac
  done <<<"$report"
}

LOCK_FILE="$RUN_DIR/lock"
exec 9>"$LOCK_FILE"
if ! flock -n 9; then
  notify "Already reading a screen selection."
  exit 0
fi

printf '%s\n' "$$" >"$ACTIVE_PID_FILE"
pgid="$(ps -o pgid= -p "$$" 2>/dev/null | tr -d '[:space:]' || true)"
if [[ "$pgid" == "$$" ]]; then
  printf '%s\n' "$pgid" >"$ACTIVE_PGID_FILE"
else
  rm -f -- "$ACTIVE_PGID_FILE"
fi

timestamp="$(date '+%Y%m%d-%H%M%S')"
shot="$RUN_DIR/selection-$timestamp.png"
ocr_file="$RUN_DIR/ocr-$timestamp.txt"
audio="$RUN_DIR/speech-$timestamp.wav"
tts_log="$RUN_DIR/tts-$timestamp.log"

cleanup() {
  local active
  active="$(read_file "$ACTIVE_PID_FILE" || true)"
  if [[ "$active" == "$$" ]]; then
    clear_active_state
  fi
  if [[ "$KEEP_ARTIFACTS" != "1" ]]; then
    rm -f -- "$shot" "$ocr_file" "$audio"
    if [[ "$FAILED" != "1" ]]; then
      rm -f -- "$tts_log"
    fi
  else
    log "Artifacts kept in $RUN_DIR with timestamp $timestamp"
  fi
}
trap cleanup EXIT

log "Starting region capture"
if ! "$SPECTACLE" --region --background --nonotify --output "$shot"; then
  die "Screenshot selection was cancelled or failed."
fi
[[ -s "$shot" ]] || die "Spectacle did not create a screenshot."

log "Starting OCR with language $OCR_LANG"
if ! "$TESSERACT" "$shot" stdout -l "$OCR_LANG" --psm "$OCR_PSM" >"$ocr_file" 2>>"$LOG_FILE"; then
  die "OCR failed. Check that Tesseract and traineddata for '$OCR_LANG' are installed."
fi

text="$(sed -e 's/[[:space:]]\+$//' "$ocr_file" | awk 'NF {blank=0; print; next} !blank {print ""; blank=1}')"
if [[ -z "${text//[[:space:]]/}" ]]; then
  die "No readable text found in the selected region."
fi

detect_text_route

tts_engine="omnivoice"
if [[ "$tts_route" == "hebrew" ]]; then
  case "$HEBREW_TTS_ENGINE" in
    auto)
      if blue_ready; then
        tts_engine="blue"
      else
        log "Hebrew text detected, but BlueTTS is not ready; falling back to OmniVoice"
      fi
      ;;
    blue)
      blue_ready || die "Hebrew text detected, but BlueTTS is not ready. Run scripts/setup-hebrew-blue."
      tts_engine="blue"
      ;;
    omnivoice|default|off|disabled|none)
      tts_engine="omnivoice"
      ;;
    *)
      die "Unknown STTS_HEBREW_TTS_ENGINE=$HEBREW_TTS_ENGINE"
      ;;
  esac
fi

log "Text route=$tts_route hebrew_chars=$hebrew_chars letter_chars=$letter_chars hebrew_ratio=$hebrew_ratio tts_engine=$tts_engine"

if [[ "$tts_engine" == "blue" ]]; then
  tts_python="$BLUE_PYTHON"
  tts_args=(
    "$PROJECT_DIR/bin/blue-hebrew-say"
    --output "$audio"
    --onnx-dir "$BLUE_ONNX_DIR"
    --style-json "$BLUE_STYLE_JSON"
    --renikud-path "$BLUE_RENIKUD_MODEL"
    --language "$BLUE_LANGUAGE"
    --speed "$BLUE_SPEED"
    --total-step "$BLUE_TOTAL_STEP"
    --max-chunk-chars "$BLUE_MAX_CHUNK_CHARS"
    --chunk-gap-ms "$BLUE_CHUNK_GAP_MS"
  )
else
  tts_python="$PYTHON"
  tts_args=(
    "$PROJECT_DIR/bin/omnivoice-say"
    --output "$audio"
    --model "$MODEL"
    --speed "$SPEED"
    --num-step "$NUM_STEP"
  )

  if [[ -n "$DEVICE" ]]; then
    tts_args+=(--device "$DEVICE")
  fi
  if [[ -n "$LANGUAGE" ]]; then
    tts_args+=(--language "$LANGUAGE")
  fi
  if [[ -n "$REF_AUDIO" ]]; then
    [[ -r "$REF_AUDIO" ]] || die "Reference audio is not readable: $REF_AUDIO"
    tts_args+=(--ref-audio "$REF_AUDIO")
  fi
  if [[ -n "$REF_TEXT_FILE" ]]; then
    [[ -r "$REF_TEXT_FILE" ]] || die "Reference text file is not readable: $REF_TEXT_FILE"
    tts_args+=(--ref-text-file "$REF_TEXT_FILE")
  elif [[ -n "$REF_TEXT" ]]; then
    tts_args+=(--ref-text "$REF_TEXT")
  fi
  if [[ -n "${STTS_OMNIVOICE_INSTRUCT:-}" ]]; then
    tts_args+=(--instruct "$STTS_OMNIVOICE_INSTRUCT")
  fi
fi

log "Starting $tts_engine synthesis"
if ! printf '%s' "$text" | "$tts_python" "${tts_args[@]}" >"$tts_log" 2>&1; then
  log "$tts_engine stderr is in $tts_log"
  die "$tts_engine synthesis failed. Run scripts/check-system, then inspect $tts_log."
fi
[[ -s "$audio" ]] || die "$tts_engine did not create an audio file."

log "Playing generated speech"
if ! "$PLAYER" "$audio" >>"$LOG_FILE" 2>&1; then
  die "Audio playback failed with $PLAYER."
fi

log "Completed successfully"
