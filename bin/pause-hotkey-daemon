#!/usr/bin/env python3
"""Grab the physical Pause/Break key on X11 and launch screenshot-read.

KDE launcher shortcuts can leave custom .desktop actions inactive on some
Plasma 6 sessions. This daemon uses a plain X11 passive grab for the actual key
instead, which is a better fit for this machine's X11 KDE session.
"""

from __future__ import annotations

import os
import signal
import select
import subprocess
import sys
import time
from pathlib import Path

from Xlib import X, XK, error
from Xlib.display import Display


PROJECT_DIR = Path(__file__).resolve().parents[1]
STATE_DIR = Path(os.environ.get("XDG_STATE_HOME", Path.home() / ".local/state")) / "screenshot-text-to-speech"
LOG_FILE = STATE_DIR / "pause-hotkey-daemon.log"
TARGET = PROJECT_DIR / "bin/screenshot-read"
DEBOUNCE_SECONDS = float(os.environ.get("STTS_HOTKEY_DEBOUNCE_SECONDS", "0.8"))


def log(message: str) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with LOG_FILE.open("a", encoding="utf-8") as f:
        f.write(f"{time.strftime('%Y-%m-%d %H:%M:%S')} {message}\n")


def keysyms() -> list[str]:
    configured = os.environ.get("STTS_HOTKEY_KEYSYMS", "Pause,Break")
    return [item.strip() for item in configured.split(",") if item.strip()]


def modifier_masks() -> list[int]:
    # NumLock is normally Mod2 on X11. Include CapsLock/NumLock variants so the
    # grab still works while those toggles are active.
    base = [0, X.LockMask, X.Mod2Mask, X.LockMask | X.Mod2Mask]
    return base


def grab_keys(display: Display) -> set[int]:
    root = display.screen().root
    grabbed: set[int] = set()
    for name in keysyms():
        keysym = XK.string_to_keysym(name)
        if keysym == X.NoSymbol:
            log(f"Unknown keysym: {name}")
            continue
        keycode = display.keysym_to_keycode(keysym)
        if keycode == 0:
            log(f"No keycode for keysym: {name}")
            continue
        if keycode in grabbed:
            log(f"Skipping duplicate {name} keycode={keycode}")
            continue
        for modifiers in modifier_masks():
            try:
                root.grab_key(keycode, modifiers, True, X.GrabModeAsync, X.GrabModeAsync)
            except error.BadAccess:
                log(f"Could not grab {name} keycode={keycode} modifiers={modifiers}: already grabbed")
                continue
        grabbed.add(keycode)
        log(f"Grabbed {name} keycode={keycode}")
    display.sync()
    return grabbed


def launch_reader() -> None:
    log(f"Toggling {TARGET}")
    subprocess.Popen(
        [str(TARGET), "--toggle"],
        cwd=str(PROJECT_DIR),
        start_new_session=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def main() -> int:
    if os.environ.get("XDG_SESSION_TYPE") not in (None, "", "x11"):
        log(f"Unsupported session type: {os.environ.get('XDG_SESSION_TYPE')}")
        return 2
    if not TARGET.exists():
        log(f"Missing target script: {TARGET}")
        return 2

    stop = False

    def handle_stop(_signum: int, _frame: object) -> None:
        nonlocal stop
        stop = True

    signal.signal(signal.SIGTERM, handle_stop)
    signal.signal(signal.SIGINT, handle_stop)

    display = Display()
    grabbed = grab_keys(display)
    if not grabbed:
        log("No keys grabbed; exiting")
        return 1

    log("Daemon ready")
    last_trigger = 0.0
    while not stop:
        ready, _, _ = select.select([display.fileno()], [], [], 0.5)
        if not ready:
            continue
        while display.pending_events():
            event = display.next_event()
            if event.type == X.KeyPress and event.detail in grabbed:
                now = time.monotonic()
                if now - last_trigger < DEBOUNCE_SECONDS:
                    log("Ignoring repeated hotkey press inside debounce window")
                    continue
                last_trigger = now
                launch_reader()
    log("Daemon stopped")
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except Exception as exc:
        log(f"Fatal error: {exc}")
        print(exc, file=sys.stderr)
        raise
