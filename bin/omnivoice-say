#!/usr/bin/env python3
"""Read text from stdin and synthesize it with OmniVoice.

The screenshot pipeline intentionally sends the OCR text through stdin instead
of command-line arguments so selected screen text is not exposed in `ps`.
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path


def parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(description="Synthesize stdin with OmniVoice")
    p.add_argument("--output", required=True, help="Output WAV path")
    p.add_argument("--model", default="k2-fsa/OmniVoice")
    p.add_argument("--ref-audio", default=None)
    p.add_argument("--ref-text", default=None)
    p.add_argument("--ref-text-file", default=None)
    p.add_argument("--instruct", default=None)
    p.add_argument("--language", default=None)
    p.add_argument("--device", default=None)
    p.add_argument("--speed", type=float, default=1.0)
    p.add_argument("--num-step", type=int, default=32)
    p.add_argument("--guidance-scale", type=float, default=2.0)
    return p


def read_ref_text(args: argparse.Namespace) -> str | None:
    if args.ref_text:
        return args.ref_text
    if args.ref_text_file:
        path = Path(args.ref_text_file).expanduser()
        if path.is_file():
            return path.read_text(encoding="utf-8").strip() or None
    return None


def main() -> int:
    args = parser().parse_args()
    text = sys.stdin.read().strip()
    if not text:
        print("No text received on stdin.", file=sys.stderr)
        return 2

    try:
        import soundfile as sf
        import torch
        try:
            from omnivoice import OmniVoice
        except ImportError:
            from omnivoice.models.omnivoice import OmniVoice
        try:
            from omnivoice.utils.common import get_best_device
        except ImportError:
            get_best_device = None
    except Exception as exc:  # pragma: no cover - depends on local ML env
        print(f"Unable to import OmniVoice dependencies: {exc}", file=sys.stderr)
        return 3

    if args.device:
        device = args.device
    elif get_best_device is not None:
        device = get_best_device()
    else:
        device = "cuda:0" if torch.cuda.is_available() else "cpu"

    dtype = torch.float32 if str(device).startswith("cpu") else torch.float16
    print(f"Loading OmniVoice model on {device}...", file=sys.stderr)
    model = OmniVoice.from_pretrained(args.model, device_map=device, dtype=dtype)

    print("Generating speech...", file=sys.stderr)
    audios = model.generate(
        text=text,
        language=args.language,
        ref_audio=args.ref_audio,
        ref_text=read_ref_text(args),
        instruct=args.instruct,
        num_step=args.num_step,
        guidance_scale=args.guidance_scale,
        speed=args.speed,
    )

    output = Path(args.output).expanduser()
    output.parent.mkdir(parents=True, exist_ok=True)
    sf.write(str(output), audios[0], model.sampling_rate)
    print(f"Saved {output}", file=sys.stderr)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
