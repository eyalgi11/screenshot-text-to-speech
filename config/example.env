# Copy to config/screenshot-tts.env and edit.

# OCR language codes use Tesseract names. English is "eng"; Hebrew is "heb".
# Use eng+heb if both traineddata packages are installed.
STTS_OCR_LANG=eng
STTS_OCR_PSM=6
STTS_OCR_PREPROCESS=auto
STTS_OCR_PREPROCESS_MIN_CONFIDENCE=50
STTS_OCR_PREPROCESS_MIN_WORDS=3
STTS_OCR_QUALITY_GATE=normal
STTS_OCR_QUALITY_MIN_CONFIDENCE=35
STTS_OCR_QUALITY_MIN_WORDS=2
STTS_OCR_QUALITY_MIN_CHARS=4
STTS_OCR_QUALITY_MAX_JUNK_RATIO=0.42
STTS_OCR_QUALITY_MIN_AGREEMENT=0.60
STTS_OCR_FALLBACK_BIN=
STTS_OCR_FALLBACK_ROUTES=default
STTS_PADDLEOCR_PYTHON=
STTS_PADDLEOCR_LANG=auto
STTS_PADDLEOCR_DEVICE=
STTS_PADDLEOCR_VERSION=PP-OCRv6
STTS_PADDLEOCR_ENGINE=transformers
STTS_PADDLEOCR_DET_MODEL=
STTS_PADDLEOCR_REC_MODEL=
STTS_PADDLEOCR_MIN_SCORE=0.0

# OmniVoice reference voice. Use scripts/record-reference-voice to create these,
# then set absolute paths here. Leave blank when using voice design through
# STTS_OMNIVOICE_INSTRUCT.
STTS_REF_AUDIO=
STTS_REF_TEXT_FILE=

# OmniVoice model and generation settings.
STTS_OMNIVOICE_MODEL=k2-fsa/OmniVoice
STTS_OMNIVOICE_DEVICE=
STTS_OMNIVOICE_LANGUAGE=en
STTS_OMNIVOICE_INSTRUCT=
STTS_OMNIVOICE_SPEED=1.0
STTS_OMNIVOICE_NUM_STEP=32

# Hebrew-heavy OCR text can be routed to BlueTTS/Blue ONNX, which is better
# tuned for Hebrew than the default OmniVoice route.
# auto = use Blue when setup files exist, otherwise fall back to OmniVoice.
# blue = require Blue for Hebrew and fail clearly if it is not set up.
STTS_HEBREW_TTS_ENGINE=auto
STTS_HEBREW_ROUTE_THRESHOLD=0.35
STTS_HEBREW_ROUTE_MIN_CHARS=3
STTS_BLUE_ONNX_DIR=
STTS_BLUE_STYLE_JSON=
STTS_BLUE_RENIKUD_MODEL=
STTS_BLUE_PYTHON=
STTS_BLUE_LANGUAGE=he
STTS_BLUE_SPEED=1.05
STTS_BLUE_TOTAL_STEP=16
STTS_BLUE_MAX_CHUNK_CHARS=80
STTS_BLUE_CHUNK_GAP_MS=180

# Runtime behavior.
STTS_KEEP_ARTIFACTS=0
STTS_PLAYER=pw-play
STTS_SPECTACLE=spectacle
STTS_TESSERACT=tesseract
