# Copy to config/screenshot-tts.env and edit.

# OCR language codes use Tesseract names. English is "eng"; Hebrew is "heb".
# Use eng+heb if both traineddata packages are installed.
STTS_OCR_LANG=eng
STTS_OCR_PSM=6

# OmniVoice reference voice. Use scripts/record-reference-voice to create these,
# then set absolute paths here. Leave blank when using voice design through
# STTS_OMNIVOICE_INSTRUCT.
STTS_REF_AUDIO=
STTS_REF_TEXT_FILE=

# OmniVoice model and generation settings.
STTS_OMNIVOICE_MODEL=k2-fsa/OmniVoice
STTS_OMNIVOICE_DEVICE=
STTS_OMNIVOICE_LANGUAGE=en
STTS_OMNIVOICE_INSTRUCT=
STTS_OMNIVOICE_SPEED=1.0
STTS_OMNIVOICE_NUM_STEP=32

# Runtime behavior.
STTS_KEEP_ARTIFACTS=0
STTS_PLAYER=pw-play
STTS_SPECTACLE=spectacle
STTS_TESSERACT=tesseract
